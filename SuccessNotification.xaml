<Window x:Class="AdHealthMonitor.SuccessNotification"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Success"
        Width="420"
        Height="290"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        Background="Transparent"
        AllowsTransparency="True"
        ResizeMode="NoResize"
        ShowInTaskbar="False">
        <Border Background="#EEF3F8"
                CornerRadius="16"
                BorderBrush="#D7E2EC"
                BorderThickness="1"
                Padding="28">
            <Border.Effect>
                <DropShadowEffect BlurRadius="12" ShadowDepth="3" Opacity="0.25" Color="Black"/>
            </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border x:Name="IconBorder" Width="64" Height="64"
                    CornerRadius="32"
                    Background="#2E7D32"
                    HorizontalAlignment="Center"
                    Margin="0,0,0,14">
                <TextBlock x:Name="IconText"
                           Text="✔"
                           FontSize="34"
                           Foreground="White"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"/>
            </Border>

            <TextBlock x:Name="TitleText"
                       Grid.Row="1"
                       Text="Success"
                       FontSize="20"
                       FontWeight="Bold"
                       Foreground="#17324D"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,6"/>

            <TextBlock x:Name="MessageText"
                       Grid.Row="2"
                       TextWrapping="Wrap"
                       TextAlignment="Center"
                       FontSize="14"
                       Foreground="#4A5B6C"
                       Margin="0,0,0,20"/>

            <Border Grid.Row="4"
                    Width="100" Height="36"
                    HorizontalAlignment="Center"
                    CornerRadius="8">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Effect">
                            <Setter.Value>
                                <DropShadowEffect BlurRadius="4" Opacity="0.15" ShadowDepth="1" Color="Black"/>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Border.Style>
                <Button Content="OK"
                        Width="100" Height="36"
                        Background="#1A73E8"
                        Foreground="White"
                        BorderThickness="0"
                        FontSize="14"
                        FontWeight="SemiBold"
                        Cursor="Hand"
                        Click="OkButton_Click"/>
            </Border>

            <TextBlock x:Name="AutoDismissText"
                       Grid.Row="5"
                       HorizontalAlignment="Center"
                       Margin="0,10,0,0"
                       FontSize="11"
                       Foreground="#8A9BAE"
                       Visibility="Collapsed"/>
        </Grid>
    </Border>
</Window>
