<Window x:Class="AdHealthMonitor.TaskSchedulerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Schedule Task"
        Height="660"
        Width="900"
        WindowStartupLocation="CenterScreen"
        Background="#EEF3F8"
        FontFamily="Segoe UI"
        Loaded="Window_Loaded">

    <Window.Resources>
        <SolidColorBrush x:Key="PanelBorderBrush" Color="#D7E2EC"/>
        <SolidColorBrush x:Key="HeadingBrush" Color="#17324D"/>
        <SolidColorBrush x:Key="BodyBrush" Color="#5D6F82"/>
        <Style x:Key="RoundedButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#007ACC"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="14,10"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
            <Setter Property="RenderTransform">
                <Setter.Value>
                    <ScaleTransform ScaleX="1" ScaleY="1"/>
                </Setter.Value>
            </Setter>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Border" Background="{TemplateBinding Background}" CornerRadius="10" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="Opacity" Value="0.92"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Border" Property="Opacity" Value="0.84"/>
                                <Setter Property="RenderTransform">
                                    <Setter.Value>
                                        <ScaleTransform ScaleX="0.95" ScaleY="0.95"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="LabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource HeadingBrush}"/>
            <Setter Property="Margin" Value="0,10,0,2"/>
        </Style>

        <Style x:Key="RoundedTextBoxStyle" TargetType="TextBox">
            <Setter Property="Padding" Value="8"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="BorderBrush" Value="#C7D5E2"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="Height" Value="38"/>
            <Setter Property="Margin" Value="0,5,0,10"/>
        </Style>

        <Style x:Key="RoundedComboBoxStyle" TargetType="ComboBox">
            <Setter Property="Padding" Value="5"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="BorderBrush" Value="#C7D5E2"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="Height" Value="38"/>
            <Setter Property="Margin" Value="0,5,0,10"/>
        </Style>

        <Style x:Key="RoundedDatePickerStyle" TargetType="DatePicker">
            <Setter Property="Padding" Value="5"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="BorderBrush" Value="#C7D5E2"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="Height" Value="38"/>
            <Setter Property="Margin" Value="0,5,0,10"/>
        </Style>
        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#D7E2EC"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="RowBackground" Value="White"/>
            <Setter Property="AlternatingRowBackground" Value="#F8FBFD"/>
            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
        </Style>
        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#EDF4FA"/>
            <Setter Property="Foreground" Value="#17324D"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="BorderBrush" Value="#D7E2EC"/>
        </Style>
    </Window.Resources>

    <Grid Margin="12">
        <Border Background="White" Padding="18" CornerRadius="12" BorderBrush="{StaticResource PanelBorderBrush}" BorderThickness="1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.2*"/>
                    <ColumnDefinition Width="1*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Margin="0,0,14,0">
                    <TextBlock Text="Schedule a Task"
                               FontSize="22"
                               FontWeight="Bold"
                               Foreground="#007ACC"
                               HorizontalAlignment="Left"
                               Margin="0,0,0,6"/>
                    <TextBlock Text="Create, edit, or remove recurring checks without leaving the desktop workflow."
                               FontSize="13"
                               Foreground="{StaticResource BodyBrush}"
                               Margin="0,0,0,10"/>

                    <TextBlock Text="Task Name:" Style="{StaticResource LabelStyle}"/>
                    <TextBox x:Name="TaskNameTextBox" Style="{StaticResource RoundedTextBoxStyle}"/>

                    <TextBlock Text="Domain Controllers:" Style="{StaticResource LabelStyle}"/>
                    <TextBox x:Name="DomainControllerTextBox"
                             Style="{StaticResource RoundedTextBoxStyle}"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             Height="76"
                             VerticalScrollBarVisibility="Auto"/>

                    <TextBlock Text="Frequency:" Style="{StaticResource LabelStyle}"/>
                    <ComboBox x:Name="FrequencyComboBox" Style="{StaticResource RoundedComboBoxStyle}" SelectedIndex="0">
                        <ComboBoxItem Content="Daily"/>
                        <ComboBoxItem Content="Weekly"/>
                        <ComboBoxItem Content="Monthly"/>
                        <ComboBoxItem Content="Hourly"/>
                    </ComboBox>

                    <TextBlock Text="Start Date:" Style="{StaticResource LabelStyle}"/>
                    <DatePicker x:Name="StartDatePicker" Style="{StaticResource RoundedDatePickerStyle}"/>

                    <TextBlock Text="Start Time (HH:mm):" Style="{StaticResource LabelStyle}"/>
                    <TextBox x:Name="StartTimeTextBox" Style="{StaticResource RoundedTextBoxStyle}" />

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
                        <Button Content="Save"
                                Style="{StaticResource RoundedButtonStyle}"
                                Background="#007ACC"
                                Width="80"
                                Margin="0,0,10,0"
                                Click="SaveButton_Click"/>
                        <Button x:Name="RemoveTaskButton" Content="Remove"
                                Style="{StaticResource RoundedButtonStyle}"
                                Background="#D32F2F"
                                Width="90"
                                Margin="0,0,10,0"
                                IsEnabled="False"
                                Click="RemoveTaskButton_Click"/>
                        <Button Content="Cancel"
                                Style="{StaticResource RoundedButtonStyle}"
                                Background="#9E9E9E"
                                Width="80"
                                Click="CancelButton_Click"/>
                    </StackPanel>
                </StackPanel>

                <Border Grid.Column="1" Background="#F8FAFC" BorderBrush="{StaticResource PanelBorderBrush}" BorderThickness="1" CornerRadius="10" Padding="12">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <TextBlock Text="Existing Tasks"
                                   FontSize="18"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource HeadingBrush}"
                                   Margin="0,0,0,4"/>
                        <TextBlock Grid.Row="0"
                                   Margin="0,30,0,10"
                                   FontSize="12"
                                   Foreground="{StaticResource BodyBrush}"
                                   Text="Select an entry to load it back into the form for editing or removal."/>
                        <DataGrid x:Name="TaskListView" Grid.Row="1" AutoGenerateColumns="False" Margin="0,8,0,0">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Task Name" Binding="{Binding TaskName}" Width="*" />
                                <DataGridTextColumn Header="Domain Controller" Binding="{Binding DomainController}" Width="1.2*" />
                                <DataGridTextColumn Header="Frequency" Binding="{Binding Frequency}" Width="100" />
                                <DataGridTextColumn Header="Start Date" Binding="{Binding StartDate}" Width="120" />
                                <DataGridTextColumn Header="Start Time" Binding="{Binding StartTime}" Width="90" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Window>
