<UserControl x:Class="AdHealthMonitor.FindingsTabPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
                    <Grid Margin="2">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0"
                                Background="White"
                                BorderBrush="{StaticResource PanelBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="14"
                                Padding="16"
                                Margin="0,0,0,12">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="Findings"
                                               FontSize="20"
                                               FontWeight="Bold"
                                               Foreground="{StaticResource HeadingBrush}"/>
                                    <TextBlock Text="Actionable issues and remediation guidance"
                                               Margin="0,4,0,0"
                                               Foreground="{StaticResource BodyBrush}"/>
                                </StackPanel>
                                <Button Grid.Column="1"
                                        Style="{StaticResource RoundedButtonStyle}"
                                        Background="#607D8B"
                                        Width="138"
                                        Height="38"
                                        Margin="16,0,0,0"
                                        VerticalAlignment="Center"
                                        Click="BackToHealth_Click">
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <TextBlock Text="&#xE72B;"
                                                   FontFamily="Segoe MDL2 Assets"
                                                   FontSize="14"
                                                   VerticalAlignment="Center"
                                                   Margin="0,0,7,0"/>
                                        <TextBlock Text="Back to Health"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                            </Grid>
                        </Border>

                        <Border Grid.Row="1"
                                Background="{StaticResource SoftFillBrush}"
                                BorderBrush="{StaticResource PanelBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="14"
                                Padding="14"
                                Margin="0,0,0,12">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="320"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Row="0" Grid.Column="0">
                                    <TextBlock Text="Search findings" FontWeight="Bold" Foreground="{StaticResource HeadingBrush}" Margin="0,0,0,6"/>
                                    <TextBox x:Name="FindingsSearchBox" x:FieldModifier="public" Style="{StaticResource ModernTextBoxStyle}" TextChanged="FindingsSearchBox_TextChanged"/>
                                </StackPanel>

                                <TextBlock Grid.Row="0" Grid.Column="1"
                                           Text="Actionable findings combine test failures, AD inventory drift, telemetry gaps, and privilege issues into one queue."
                                           Margin="18,6,20,0"
                                           Foreground="{StaticResource BodyBrush}"
                                           VerticalAlignment="Top"
                                           TextWrapping="Wrap"/>

                                <Border Grid.Row="1" Grid.Column="3"
                                        Margin="8,14,8,0"
                                        Padding="12,8"
                                        Background="White"
                                        BorderBrush="{StaticResource PanelBorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="10"
                                        VerticalAlignment="Top">
                                    <StackPanel>
                                        <TextBlock Text="Open Findings" FontSize="11" Foreground="{StaticResource BodyBrush}" HorizontalAlignment="Center"/>
                                        <TextBlock x:Name="FindingsOpenCountText" x:FieldModifier="public" Text="0" Margin="0,3,0,0" FontSize="18" FontWeight="Bold" Foreground="{StaticResource HeadingBrush}" HorizontalAlignment="Center"/>
                                    </StackPanel>
                                </Border>

                                <Border Grid.Row="1" Grid.Column="4"
                                        Margin="0,14,8,0"
                                        Padding="12,8"
                                        Background="#FFF4E5"
                                        BorderBrush="#F2D3A0"
                                        BorderThickness="1"
                                        CornerRadius="10"
                                        VerticalAlignment="Top">
                                    <StackPanel>
                                        <TextBlock Text="High +" FontSize="11" Foreground="{StaticResource BodyBrush}" HorizontalAlignment="Center"/>
                                        <TextBlock x:Name="FindingsHighCountText" x:FieldModifier="public" Text="0" Margin="0,3,0,0" FontSize="18" FontWeight="Bold" Foreground="#C45D00" HorizontalAlignment="Center"/>
                                    </StackPanel>
                                </Border>

                                <Border Grid.Row="1" Grid.Column="5"
                                        Margin="0,14,0,0"
                                        Padding="12,8"
                                        Background="#FFEBEE"
                                        BorderBrush="#E8B8C1"
                                        BorderThickness="1"
                                        CornerRadius="10"
                                        VerticalAlignment="Top">
                                    <StackPanel>
                                        <TextBlock Text="Critical" FontSize="11" Foreground="{StaticResource BodyBrush}" HorizontalAlignment="Center"/>
                                        <TextBlock x:Name="FindingsCriticalCountText" x:FieldModifier="public" Text="0" Margin="0,3,0,0" FontSize="18" FontWeight="Bold" Foreground="#C62828" HorizontalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </Border>

                        <Grid Grid.Row="2">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                        <Border Grid.Row="0"
                                Background="White"
                                BorderBrush="{StaticResource PanelBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="12">
                             <DataGrid x:Name="dgFindings" x:FieldModifier="public"
                                      AutoGenerateColumns="False"
                                      BorderThickness="0"
                                      IsReadOnly="True"
                                      RowHeaderWidth="0"
                                      RowHeight="44"
                                      HeadersVisibility="Column"
                                      GridLinesVisibility="Horizontal"
                                      SelectionMode="Single"
                                      SelectionUnit="FullRow"
                                      AlternationCount="2"
                                      SelectionChanged="dgFindings_SelectionChanged"
                                      VirtualizingPanel.VirtualizationMode="Recycling"
                                      VirtualizingPanel.ScrollUnit="Item">
                                <DataGrid.Resources>
                                    <Style TargetType="DataGridRow" BasedOn="{StaticResource SelectableDataGridRowStyle}">
                                        <Style.Triggers>
                                            <Trigger Property="AlternationIndex" Value="1">
                                                <Setter Property="Background" Value="#F8FBFD"/>
                                            </Trigger>
                                            <DataTrigger Binding="{Binding Severity}" Value="Critical">
                                                <Setter Property="Background" Value="#FFF6F7"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Severity}" Value="High">
                                                <Setter Property="Background" Value="#FFFBF3"/>
                                            </DataTrigger>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter Property="Background" Value="#E3F0FF"/>
                                                <Setter Property="Foreground" Value="#13293D"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                    <Style TargetType="DataGridCell" BasedOn="{StaticResource SelectableDataGridCellStyle}">
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                        <Setter Property="Padding" Value="10,0"/>
                                    </Style>
                                </DataGrid.Resources>
                                <DataGrid.Columns>
                                    <DataGridTemplateColumn Header="Severity" Width="130">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding Severity}"
                                                           FontWeight="SemiBold"
                                                           FontSize="12"
                                                           VerticalAlignment="Center">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Foreground" Value="#607D8B"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Severity}" Value="Critical">
                                                                    <Setter Property="Foreground" Value="#C62828"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Severity}" Value="High">
                                                                    <Setter Property="Foreground" Value="#EF6C00"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Severity}" Value="Medium">
                                                                    <Setter Property="Foreground" Value="#F4A62A"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTextColumn Header="Category" Binding="{Binding Category}" Width="130" />
                                     <DataGridTextColumn Header="Target" Binding="{Binding Target}" Width="230">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="VerticalAlignment" Value="Center"/>
                                                <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                                                <Setter Property="ToolTip" Value="{Binding RelativeSource={RelativeSource Self}, Path=Text}"/>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>
                                    <DataGridTextColumn Header="Issue" Binding="{Binding Summary}" Width="1.15*">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="FontWeight" Value="SemiBold"/>
                                                <Setter Property="VerticalAlignment" Value="Center"/>
                                                <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                                                <Setter Property="ToolTip" Value="{Binding RelativeSource={RelativeSource Self}, Path=Text}"/>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>
                                    <DataGridTextColumn Header="Recommended Action" Binding="{Binding Remediation}" Width="1.2*">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="VerticalAlignment" Value="Center"/>
                                                <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                                                <Setter Property="ToolTip" Value="{Binding RelativeSource={RelativeSource Self}, Path=Text}"/>
                                                <Setter Property="Foreground" Value="{StaticResource BodyBrush}"/>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>
                                    <DataGridTextColumn Header="Source" Binding="{Binding Source}" Width="170">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="VerticalAlignment" Value="Center"/>
                                                <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                                                <Setter Property="ToolTip" Value="{Binding RelativeSource={RelativeSource Self}, Path=Text}"/>
                                                <Setter Property="Foreground" Value="{StaticResource BodyBrush}"/>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Border>
                            <Border Grid.Row="1"
                                    Background="#F7FAFD"
                                    BorderBrush="{StaticResource PanelBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="12"
                                    Padding="14"
                                    Margin="0,12,0,0">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="Finding details"
                                                   FontSize="14"
                                                   FontWeight="SemiBold"
                                                   Foreground="{StaticResource HeadingBrush}"/>
                                        <TextBlock x:Name="FindingDetailsText" x:FieldModifier="public"
                                                   Text="Select a finding to see the full explanation, evidence, and next action."
                                                   Margin="0,8,0,0"
                                                   Foreground="{StaticResource BodyBrush}"
                                                   TextWrapping="Wrap"/>
                                    </StackPanel>
                                    <Button x:Name="OpenFindingLogButton" x:FieldModifier="public"
                                            Grid.Column="1"
                                            Content="Open Related Log"
                                            Style="{StaticResource RoundedButtonStyle}"
                                            Background="#1A73E8"
                                            Width="138"
                                            Height="38"
                                            Margin="12,0,0,0"
                                            VerticalAlignment="Top"
                                            Click="OpenFindingLog_Click"/>
                                </Grid>
                            </Border>
                        </Grid>
                    </Grid>
</UserControl>
