<UserControl x:Class="AdHealthMonitor.SettingsTabPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
                    <Grid Margin="2">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Grid Margin="0,0,0,14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Settings"
                                       FontSize="22"
                                       FontWeight="Bold"
                                       Foreground="{StaticResource HeadingBrush}"/>
                            <Button Grid.Column="1"
                                    Content="Save Settings"
                                    Style="{StaticResource RoundedButtonStyle}"
                                    Background="{StaticResource SidebarActiveBrush}"
                                    Width="140"
                                    Height="38"
                                    Click="SettingsSaveButton_Click"/>
                        </Grid>
                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                            <StackPanel>
                                <Border Background="White"
                                        BorderBrush="{StaticResource PanelBorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="12"
                                        Padding="18"
                                        Margin="0,0,0,14">
                                    <StackPanel>
                                        <TextBlock Text="Domain Controllers"
                                                   FontSize="16"
                                                   FontWeight="SemiBold"
                                                   Foreground="{StaticResource HeadingBrush}"
                                                   Margin="0,0,0,4"/>
                                        <TextBlock Text="Comma-separated list of DC hostnames or IPs."
                                                   Foreground="{StaticResource BodyBrush}"
                                                   FontSize="13"
                                                   Margin="0,0,0,10"/>
                                        <TextBox x:Name="SettingsDcTextBox" x:FieldModifier="public"
                                                 FontSize="14"
                                                 Padding="10,8"
                                                 BorderBrush="#C7D5E2"
                                                 BorderThickness="1"
                                                 Background="White"/>
                                    </StackPanel>
                                </Border>

                                 <Border Background="White"
                                         BorderBrush="{StaticResource PanelBorderBrush}"
                                         BorderThickness="1"
                                         CornerRadius="12"
                                         Padding="18"
                                         Margin="0,0,0,14">
                                     <StackPanel>
                                         <TextBlock Text="Email Notifications"
                                                    FontSize="16"
                                                    FontWeight="SemiBold"
                                                    Foreground="{StaticResource HeadingBrush}"
                                                    Margin="0,0,0,4"/>
                                         <TextBlock Text="Recipient address for test result emails."
                                                    Foreground="{StaticResource BodyBrush}"
                                                    FontSize="13"
                                                    Margin="0,0,0,10"/>
                                         <TextBox x:Name="SettingsEmailTextBox" x:FieldModifier="public"
                                                  FontSize="14"
                                                  Padding="10,8"
                                                  BorderBrush="#C7D5E2"
                                                  BorderThickness="1"
                                                  Background="White"/>
                                          <CheckBox x:Name="SettingsChkEmailManual" x:FieldModifier="public"
                                                    Style="{StaticResource SettingsCheckBoxStyle}"
                                                    Content="Send email on manual runs"
                                                    Margin="0,10,0,6"
                                                    IsChecked="True"/>
                                          <CheckBox x:Name="SettingsChkEmailScheduled" x:FieldModifier="public"
                                                    Style="{StaticResource SettingsCheckBoxStyle}"
                                                    Content="Send email on scheduled runs"
                                                    Margin="0,0,0,4"
                                                    IsChecked="True"/>
                                     </StackPanel>
                                 </Border>

                                 <Border Background="White"
                                         BorderBrush="{StaticResource PanelBorderBrush}"
                                         BorderThickness="1"
                                         CornerRadius="12"
                                         Padding="18"
                                         Margin="0,0,0,14">
                                     <StackPanel>
                                         <TextBlock Text="Optional Tests"
                                                   FontSize="16"
                                                   FontWeight="SemiBold"
                                                   Foreground="{StaticResource HeadingBrush}"
                                                   Margin="0,0,0,4"/>
                                        <TextBlock Text="Toggle which additional checks run with each test. DCDiag (dcdiag /c /v) always runs."
                                                   Foreground="{StaticResource BodyBrush}"
                                                   FontSize="13"
                                                   Margin="0,0,0,12"/>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel>
                                                <CheckBox x:Name="SettingsChkDns" x:FieldModifier="public" Style="{StaticResource SettingsCheckBoxStyle}" Content="DNS Resolution" Margin="0,0,0,2" IsChecked="True"/>
                                                <TextBlock Text="Runs: nslookup &lt;DC&gt;" Foreground="#8A97A6" FontSize="11" Margin="24,0,0,10"/>
                                                <CheckBox x:Name="SettingsChkReplication" x:FieldModifier="public" Style="{StaticResource SettingsCheckBoxStyle}" Content="Replication (repadmin)" Margin="0,0,0,2" IsChecked="True"/>
                                                <TextBlock Text="Runs: repadmin /showrepl &lt;DC&gt; and repadmin /replsummary" Foreground="#8A97A6" FontSize="11" Margin="24,0,0,10"/>
                                                <CheckBox x:Name="SettingsChkTimeSkew" x:FieldModifier="public" Style="{StaticResource SettingsCheckBoxStyle}" Content="Time Skew (w32tm)" Margin="0,0,0,2" IsChecked="True"/>
                                                <TextBlock Text="Runs: w32tm /monitor /computers:&lt;DC&gt;" Foreground="#8A97A6" FontSize="11" Margin="24,0,0,10"/>
                                            </StackPanel>
                                            <StackPanel Grid.Column="1">
                                                <CheckBox x:Name="SettingsChkLdapBind" x:FieldModifier="public" Style="{StaticResource SettingsCheckBoxStyle}" Content="LDAP Bind" Margin="0,0,0,2" IsChecked="True"/>
                                                <TextBlock Text="Runs: PowerShell ADSI LDAP bind test" Foreground="#8A97A6" FontSize="11" Margin="24,0,0,10"/>
                                                <CheckBox x:Name="SettingsChkCertDhcp" x:FieldModifier="public" Style="{StaticResource SettingsCheckBoxStyle}" Content="Cert Services &amp; DHCP" Margin="0,0,0,2" IsChecked="True"/>
                                                <TextBlock Text="Runs: Get-Service ADCS, DhcpServer" Foreground="#8A97A6" FontSize="11" Margin="24,0,0,10"/>
                                                <CheckBox x:Name="SettingsChkSmbSigning" x:FieldModifier="public" Style="{StaticResource SettingsCheckBoxStyle}" Content="SMB/LDAP Signing" Margin="0,0,0,2" IsChecked="True"/>
                                                <TextBlock Text="Runs: Get-Service LanmanServer" Foreground="#8A97A6" FontSize="11" Margin="24,0,0,10"/>
                                            </StackPanel>
                                        </Grid>
                                        <Border Background="#F0F7FF" BorderBrush="#C5D9F1" BorderThickness="1" CornerRadius="8" Padding="12,10" Margin="0,6,0,0">
                                            <StackPanel>
                                                <TextBlock FontSize="12" TextWrapping="Wrap" Foreground="#3565A0">
                                                    <Run FontWeight="SemiBold">Matching your manual commands:</Run>
                                                    <Run Text=" DCDiag (/c /v) always runs as the base test — this matches your manual dcdiag command. To include repadmin output (/showrepl and /replsummary), ensure " /><Run FontWeight="SemiBold">Replication (repadmin)</Run><Run Text=" is checked. All other options are additional checks that go beyond those commands."/>
                                                </TextBlock>
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>
                                </Border>

                                <Border Background="White"
                                        BorderBrush="{StaticResource PanelBorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="12"
                                        Padding="18"
                                        Margin="0,0,0,14">
                                    <StackPanel>
                                        <TextBlock Text="Email Test"
                                                   FontSize="16"
                                                   FontWeight="SemiBold"
                                                   Foreground="{StaticResource HeadingBrush}"
                                                   Margin="0,0,0,4"/>
                                        <TextBlock Text="Send a test email to verify SMTP configuration."
                                                   Foreground="{StaticResource BodyBrush}"
                                                   FontSize="13"
                                                   Margin="0,0,0,10"/>
                                         <Button x:Name="SettingsTestEmailButton" x:FieldModifier="public"
                                                 Content="Send Test Email"
                                                 Style="{StaticResource RoundedButtonStyle}"
                                                 Background="#2E7D32"
                                                 Width="140"
                                                 Height="36"
                                                 HorizontalAlignment="Left"
                                                 Click="TestEmailButton_Click"/>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </ScrollViewer>
                    </Grid>
</UserControl>
