<UserControl x:Class="AdHealthMonitor.LogsTabPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
                    <Grid Margin="2">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0"
                                Background="White"
                                BorderBrush="{StaticResource PanelBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="14"
                                Padding="16"
                                Margin="0,0,0,12">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="Logs"
                                               FontSize="20"
                                               FontWeight="Bold"
                                               Foreground="{StaticResource HeadingBrush}"/>
                                    <TextBlock Text="Diagnostic log output"
                                               Margin="0,4,0,0"
                                               Foreground="{StaticResource BodyBrush}"/>
                                </StackPanel>

                            </Grid>
                        </Border>

                        <Border Grid.Row="1"
                                Background="{StaticResource SoftFillBrush}"
                                BorderBrush="{StaticResource PanelBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="14"
                                Padding="16"
                                Margin="0,0,0,12"
                                VerticalAlignment="Top">
                            <Grid VerticalAlignment="Top">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Row="0" Grid.Column="0">
                                    <TextBlock Text="Logs Workspace"
                                               FontSize="16"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource HeadingBrush}"/>
                                    <TextBlock x:Name="LogsSummaryText" x:FieldModifier="public"
                                               Text="Open and inspect the raw combined log directly. This view now prioritises the full evidence rather than parsed subsections."
                                               Margin="0,4,0,0"
                                               Foreground="{StaticResource BodyBrush}"
                                               TextWrapping="Wrap"/>
                                </StackPanel>

                                <WrapPanel Grid.Row="1"
                                           Grid.ColumnSpan="2"
                                           Margin="0,14,0,0"
                                           VerticalAlignment="Top"
                                           MinHeight="46">
                                    <ComboBox x:Name="LogsDcFilter" x:FieldModifier="public"
                                              Width="190"
                                              Height="38"
                                              Margin="0,0,8,6"
                                              VerticalAlignment="Center"
                                              SelectionChanged="LogsFilter_Changed"/>
                                    <ComboBox x:Name="LogsResultFilter" x:FieldModifier="public"
                                              Width="150"
                                              Height="38"
                                              Margin="0,0,8,6"
                                              VerticalAlignment="Center"
                                              SelectionChanged="LogsFilter_Changed"/>
                                    <ComboBox x:Name="LogsSectionFilter" x:FieldModifier="public"
                                              Width="210"
                                              Height="38"
                                              Margin="0,0,8,6"
                                              VerticalAlignment="Center"
                                              SelectionChanged="LogsFilter_Changed"/>
                                    <Grid Width="260" Height="38" Margin="0,0,8,6" VerticalAlignment="Center">
                                        <TextBox x:Name="LogsSearchBox" x:FieldModifier="public"
                                                 Style="{StaticResource ModernTextBoxStyle}"
                                                 VerticalAlignment="Stretch"
                                                 TextChanged="LogsSearchBox_TextChanged"
                                                 GotFocus="LogsSearchBox_GotFocus"
                                                 LostFocus="LogsSearchBox_LostFocus"
                                                 ToolTip="Search within the visible raw log"/>
                                        <TextBlock x:Name="LogsSearchPlaceholder" x:FieldModifier="public"
                                                   Text="Search log..."
                                                   FontSize="13"
                                                   Foreground="{StaticResource SubtleInkBrush}"
                                                   Margin="10,0,0,0"
                                                   VerticalAlignment="Center"
                                                   IsHitTestVisible="False"/>
                                    </Grid>
<Button Content="Clear"
                                            Style="{StaticResource RoundedButtonStyle}"
                                            Background="#607D8B"
                                            Width="96"
                                            Height="38"
                                            Margin="0,0,8,6"
                                            Click="ClearLogsFilters_Click"/>
                                    <Button Content="Open Log..."
                                            Style="{StaticResource RoundedButtonStyle}"
                                            Background="#1A73E8"
                                            Width="110"
                                            Height="38"
                                            Margin="0,0,0,6"
                                            Click="OpenLogFile_Click"/>
                                </WrapPanel>
                            </Grid>
                        </Border>

                        <Border Grid.Row="2"
                                Background="White"
                                BorderBrush="{StaticResource PanelBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="12"
                                Padding="14"
                                Margin="0,0,0,12"
                                VerticalAlignment="Top"
                                Visibility="Collapsed">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Border Background="#FFF6F7"
                                        BorderBrush="#E8B8C1"
                                        BorderThickness="1"
                                        CornerRadius="10"
                                        Padding="12,8"
                                        Margin="0,0,8,0">
                                    <StackPanel>
                                        <TextBlock Text="Visible Entries" FontSize="11" Foreground="{StaticResource BodyBrush}" HorizontalAlignment="Center"/>
                                        <TextBlock x:Name="LogsVisibleCountText" x:FieldModifier="public" Text="0" Margin="0,3,0,0" FontSize="18" FontWeight="Bold" Foreground="{StaticResource HeadingBrush}" HorizontalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                                <Border Grid.Column="1"
                                        Background="#FFEBEE"
                                        BorderBrush="#E8B8C1"
                                        BorderThickness="1"
                                        CornerRadius="10"
                                        Padding="12,8"
                                        Margin="0,0,8,0">
                                    <StackPanel>
                                        <TextBlock Text="Failures" FontSize="11" Foreground="{StaticResource BodyBrush}" HorizontalAlignment="Center"/>
                                        <TextBlock x:Name="LogsFailureCountText" x:FieldModifier="public" Text="0" Margin="0,3,0,0" FontSize="18" FontWeight="Bold" Foreground="#C62828" HorizontalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                                <Border Grid.Column="2"
                                        Background="#E8F5E9"
                                        BorderBrush="#B8DDBB"
                                        BorderThickness="1"
                                        CornerRadius="10"
                                        Padding="12,8"
                                        Margin="0,0,8,0">
                                    <StackPanel>
                                        <TextBlock Text="Passes" FontSize="11" Foreground="{StaticResource BodyBrush}" HorizontalAlignment="Center"/>
                                        <TextBlock x:Name="LogsPassCountText" x:FieldModifier="public" Text="0" Margin="0,3,0,0" FontSize="18" FontWeight="Bold" Foreground="#2E7D32" HorizontalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                                <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center"/>
                            </Grid>
                        </Border>

                        <Grid Grid.Row="3" Margin="0,0,0,4" VerticalAlignment="Stretch">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="0"/>
                                <ColumnDefinition Width="0"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <GridSplitter Grid.Column="1"
                                          Width="4"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Stretch"
                                          Background="#D9E4EF"
                                          ShowsPreview="True"
                                          ResizeDirection="Columns"
                                          Visibility="Collapsed"/>

                            <Border Grid.Column="0"
                                    Background="White"
                                    BorderBrush="{StaticResource PanelBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="12"
                                    Padding="0"
                                    Margin="0,0,8,0"
                                    Visibility="Collapsed">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>
                                    <Border Background="{StaticResource SoftFillBrush}"
                                            BorderBrush="{StaticResource PanelBorderBrush}"
                                            BorderThickness="0,0,0,1"
                                            CornerRadius="12,12,0,0"
                                            Padding="12,10">
                                        <TextBlock Text="Log Sections"
                                                   FontSize="14"
                                                   FontWeight="SemiBold"
                                                   Foreground="{StaticResource HeadingBrush}"/>
                                    </Border>
                                    <DataGrid Grid.Row="1"
                                              x:Name="dgLogsEntries" x:FieldModifier="public"
                                              AutoGenerateColumns="False"
                                              BorderThickness="0"
                                              IsReadOnly="True"
                                              RowHeaderWidth="0"
                                              RowHeight="46"
                                              HeadersVisibility="Column"
                                              GridLinesVisibility="Horizontal"
                                              SelectionMode="Single"
                                              SelectionUnit="FullRow"
                                              AlternationCount="2"
                                              VirtualizingPanel.VirtualizationMode="Recycling"
                                              VirtualizingPanel.ScrollUnit="Item"
                                              ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                              SelectionChanged="dgLogsEntries_SelectionChanged">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="Service" Binding="{Binding Service}" Width="160"/>
                                            <DataGridTextColumn Header="Server" Binding="{Binding Server}" Width="120"/>
                                            <DataGridTextColumn Header="Result" Binding="{Binding Result}" Width="74">
                                                <DataGridTextColumn.ElementStyle>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                                        <Setter Property="HorizontalAlignment" Value="Center"/>
                                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                                    </Style>
                                                </DataGridTextColumn.ElementStyle>
                                            </DataGridTextColumn>
                                            <DataGridTextColumn Header="Message" Binding="{Binding Message}" Width="300">
                                                <DataGridTextColumn.ElementStyle>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                                    </Style>
                                                </DataGridTextColumn.ElementStyle>
                                            </DataGridTextColumn>
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </Grid>
                            </Border>

                            <Border Grid.Column="2"
                                Background="#F7FAFD"
                                BorderBrush="{StaticResource PanelBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="12"
                                Padding="0"
                                Margin="0,0,0,0">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>
                                    <Border Background="{StaticResource SoftFillBrush}"
                                            BorderBrush="{StaticResource PanelBorderBrush}"
                                            BorderThickness="0,0,0,1"
                                            CornerRadius="12,12,0,0"
                                            Padding="12,10">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel>
                                                <TextBlock Text="Raw Log Evidence"
                                                           FontSize="14"
                                                           FontWeight="SemiBold"
                                                           Foreground="{StaticResource HeadingBrush}"/>
                                                <TextBlock x:Name="LogsFileNameText" x:FieldModifier="public"
                                                           Text="No log loaded"
                                                           Margin="0,3,0,0"
                                                           FontSize="12"
                                                           Foreground="{StaticResource BodyBrush}"/>
                                            </StackPanel>
                                            <Button x:Name="PopOutLogViewerButton" x:FieldModifier="public"
                                                    Grid.Column="1"
                                                    Style="{StaticResource IconButtonStyle}"
                                                    Width="36"
                                                    Height="36"
                                                    Background="#1A73E8"
                                                    FontSize="16"
                                                    VerticalAlignment="Center"
                                                    ToolTip="Open raw log in a separate window"
                                                    Click="PopOutLogViewer_Click">
                                                <TextBlock Text="&#xE8A7;" FontFamily="Segoe MDL2 Assets" FontSize="16"/>
                                            </Button>
                                        </Grid>
                                    </Border>
                                    <ListBox Grid.Row="1"
                                             x:Name="LogsListBox" x:FieldModifier="public"
                                             Background="Transparent"
                                             BorderThickness="0"
                                             ScrollViewer.CanContentScroll="True"
                                             ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                             ScrollViewer.IsDeferredScrollingEnabled="True"
                                             VirtualizingPanel.IsVirtualizing="True"
                                             VirtualizingPanel.VirtualizationMode="Recycling"
                                             VirtualizingPanel.ScrollUnit="Item"
                                             FontFamily="Consolas"
                                             FontSize="13"
                                             IsTextSearchEnabled="False"
                                             Padding="8">
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding Text}"
                                                           Foreground="{Binding Foreground}"
                                                           FontWeight="{Binding FontWeight}"
                                                           TextWrapping="NoWrap"
                                                           Padding="6,1"/>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                </Grid>
                            </Border>
                        </Grid>
                    </Grid>
</UserControl>
