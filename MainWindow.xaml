                            <Border Grid.Column="1" Background="White" BorderBrush="{StaticResource PanelBorderBrush}" BorderThickness="1" CornerRadius="14" Padding="16" Margin="6,0">
                                <StackPanel>
                                    <TextBlock Text="Domain" FontSize="12" Foreground="{StaticResource BodyBrush}"/>
                                    <TextBlock x:Name="DomainNameText" Text="Unavailable" Margin="0,4,0,0" FontSize="16" FontWeight="SemiBold" Foreground="{StaticResource HeadingBrush}"/>
                                </StackPanel>
                            </Border>
                            <Border Grid.Column="2" Background="White" BorderBrush="{StaticResource PanelBorderBrush}" BorderThickness="1" CornerRadius="14" Padding="16" Margin="6,0,0,0">
                                <StackPanel>
                                    <TextBlock Text="Mode" FontSize="12" Foreground="{StaticResource BodyBrush}"/>
                                    <TextBlock x:Name="DomainModeText" Text="Unavailable" Margin="0,4,0,0" FontSize="16" FontWeight="SemiBold" Foreground="{StaticResource HeadingBrush}"/>
                                </StackPanel>
                            </Border>
                        </Grid>

                        <Grid Grid.Row="1">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <TextBlock x:Name="InfrastructureSummaryText"
                                       Text="Run a collection to populate infrastructure breadth."
                                       Foreground="{StaticResource BodyBrush}"
                                       Margin="0,0,0,12"/>

                            <Grid Grid.Row="1">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <Border Grid.Row="0" Grid.Column="0" Margin="0,0,10,10" Background="White" BorderBrush="{StaticResource PanelBorderBrush}" BorderThickness="1" CornerRadius="12" Padding="16">
                                    <StackPanel><TextBlock Text="Organizational Units" FontSize="12" Foreground="{StaticResource BodyBrush}"/><TextBlock x:Name="OuCountText" Text="0" Margin="0,4,0,0" FontSize="24" FontWeight="Bold" Foreground="{StaticResource HeadingBrush}"/></StackPanel>
                                </Border>
                                <Border Grid.Row="0" Grid.Column="1" Margin="10,0,10,10" Background="White" BorderBrush="{StaticResource PanelBorderBrush}" BorderThickness="1" CornerRadius="12" Padding="16">
                                    <StackPanel><TextBlock Text="Group Policies" FontSize="12" Foreground="{StaticResource BodyBrush}"/><TextBlock x:Name="GpoCountText" Text="0" Margin="0,4,0,0" FontSize="24" FontWeight="Bold" Foreground="{StaticResource HeadingBrush}"/></StackPanel>
                                </Border>
                                <Border Grid.Row="0" Grid.Column="2" Margin="10,0,0,10" Background="White" BorderBrush="{StaticResource PanelBorderBrush}" BorderThickness="1" CornerRadius="12" Padding="16">
                                    <StackPanel><TextBlock Text="Trusts" FontSize="12" Foreground="{StaticResource BodyBrush}"/><TextBlock x:Name="TrustCountText" Text="0" Margin="0,4,0,0" FontSize="24" FontWeight="Bold" Foreground="{StaticResource HeadingBrush}"/></StackPanel>
                                </Border>
                                <Border Grid.Row="1" Grid.Column="0" Margin="0,10,10,0" Background="White" BorderBrush="{StaticResource PanelBorderBrush}" BorderThickness="1" CornerRadius="12" Padding="16">
                                    <StackPanel><TextBlock Text="Users" FontSize="12" Foreground="{StaticResource BodyBrush}"/><TextBlock x:Name="UserCountText" Text="0" Margin="0,4,0,0" FontSize="24" FontWeight="Bold" Foreground="{StaticResource HeadingBrush}"/></StackPanel>
                                </Border>
                                <Border Grid.Row="1" Grid.Column="1" Margin="10,10,10,0" Background="White" BorderBrush="{StaticResource PanelBorderBrush}" BorderThickness="1" CornerRadius="12" Padding="16">
                                    <StackPanel><TextBlock Text="Computers" FontSize="12" Foreground="{StaticResource BodyBrush}"/><TextBlock x:Name="ComputerCountText" Text="0" Margin="0,4,0,0" FontSize="24" FontWeight="Bold" Foreground="{StaticResource HeadingBrush}"/></StackPanel>
                                </Border>
                                <Border Grid.Row="1" Grid.Column="2" Margin="10,10,0,0" Background="White" BorderBrush="{StaticResource PanelBorderBrush}" BorderThickness="1" CornerRadius="12" Padding="16">
                                    <StackPanel><TextBlock Text="DC Inventory" FontSize="12" Foreground="{StaticResource BodyBrush}"/><TextBlock x:Name="InfrastructureDcCountText" Text="0" Margin="0,4,0,0" FontSize="24" FontWeight="Bold" Foreground="{StaticResource HeadingBrush}"/></StackPanel>
                                </Border>
                            </Grid>
                        </Grid>
                    </Grid>
                </TabItem>

                <TabItem Header="History">
                    <Grid Margin="2">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0"
                                Background="{StaticResource SoftFillBrush}"
                                BorderBrush="{StaticResource PanelBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="14"
                                Padding="14"
                                Margin="0,0,0,12">
