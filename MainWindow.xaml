                            <Button x:Name="FindingsNavButton" Tag="2" Click="NavSectionButton_Click" Style="{StaticResource SidebarNavButtonStyle}" Margin="0,0,0,4"><StackPanel Orientation="Horizontal"><TextBlock Text="&#x276F;" Margin="0,0,10,0" FontSize="10"/><TextBlock x:Name="FindingsNavLabel" Text="Findings"/></StackPanel></Button>
