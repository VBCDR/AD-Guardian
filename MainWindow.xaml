                                    </Grid>
                                    </Border>

                         <Grid Grid.Row="1" Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Background="White" BorderBrush="{StaticResource PanelBorderBrush}" BorderThickness="1" CornerRadius="14" Padding="16" Margin="0,0,6,0">
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="Health Score" FontSize="16" FontWeight="SemiBold" Foreground="{StaticResource HeadingBrush}"/>
                                    <TextBlock x:Name="HealthScoreText" Text="100" FontSize="22" FontWeight="Bold" Foreground="{StaticResource HeadingBrush}" Margin="0,4,0,0"/>
                                </StackPanel>
                            </Border>
                            <Border Grid.Column="1" Background="White" BorderBrush="{StaticResource PanelBorderBrush}" BorderThickness="1" CornerRadius="14" Padding="16" Margin="6,0">
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="Critical" FontSize="16" FontWeight="SemiBold" Foreground="{StaticResource HeadingBrush}"/>
                                    <TextBlock x:Name="CriticalFindingsText" Text="0" FontSize="22" FontWeight="Bold" Foreground="#D32F2F" Margin="0,4,0,0"/>
                                </StackPanel>
                            </Border>
                            <Border Grid.Column="2" Background="White" BorderBrush="{StaticResource PanelBorderBrush}" BorderThickness="1" CornerRadius="14" Padding="16" Margin="6,0">
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="Passing" FontSize="16" FontWeight="SemiBold" Foreground="{StaticResource HeadingBrush}"/>
                                    <TextBlock x:Name="PassingTestsText" Text="0" FontSize="22" FontWeight="Bold" Foreground="#2E7D32" Margin="0,4,0,0"/>
                                </StackPanel>
                            </Border>
                            <Border Grid.Column="3" Background="White" BorderBrush="{StaticResource PanelBorderBrush}" BorderThickness="1" CornerRadius="14" Padding="16" Margin="6,0,0,0">
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="DCs" FontSize="16" FontWeight="SemiBold" Foreground="{StaticResource HeadingBrush}"/>
                                    <TextBlock x:Name="DomainControllerCountText" Text="0" FontSize="22" FontWeight="Bold" Foreground="{StaticResource HeadingBrush}" Margin="0,4,0,0"/>
                                </StackPanel>
                            </Border>
                        </Grid>

                        <Border x:Name="DetailsPanel"
                                Grid.Row="2"
                                Background="#F7FAFD"
                                BorderBrush="#D7E2EC"
                                BorderThickness="1"
                                CornerRadius="10"
                                Padding="10"
                                Margin="0,0,0,10"
                                Visibility="Collapsed">
                            <TextBox x:Name="ResultsTextBox"
                                     AcceptsReturn="True"
                                     IsReadOnly="True"
                                     Style="{StaticResource ModernTextBoxStyle}"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     Padding="6"
                                     MaxHeight="80"
                                     VerticalScrollBarVisibility="Auto"
                                     TextWrapping="Wrap"/>
                        </Border>

                        <Grid Grid.Row="3" Margin="0,0,0,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <Border Grid.Row="0"
                                    Background="White"
                                    BorderBrush="{StaticResource PanelBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="12"
                                    Padding="0"
                                    Margin="0,0,0,10">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>
                                    <Border Background="{StaticResource SoftFillBrush}"
                                            BorderBrush="{StaticResource PanelBorderBrush}"
                                            BorderThickness="0,0,0,1"
                                            CornerRadius="12,12,0,0"
                                            Padding="12,10">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                <TextBlock Text="Results"
                                                           FontSize="14"
                                                           FontWeight="SemiBold"
                                                           Foreground="{StaticResource HeadingBrush}"
                                                           VerticalAlignment="Center"/>
                                                <Border Background="{StaticResource SoftFillBrush}"
                                                        CornerRadius="8"
                                                        Padding="4"
                                                        Margin="12,0,0,0">
                                                    <StackPanel Orientation="Horizontal">
                                                        <Grid>
                                                            <TextBox x:Name="SearchBox"
                                                                     Width="200"
                                                                     Height="30"
                                                                     Style="{StaticResource ModernTextBoxStyle}"
                                                                     TextChanged="SearchBox_TextChanged"
                                                                     GotFocus="SearchBox_GotFocus"
                                                                     LostFocus="SearchBox_LostFocus"
                                                                     VerticalAlignment="Center"/>
                                                            <TextBlock x:Name="SearchPlaceholder"
                                                                       Text="Search results..."
                                                                       FontSize="13"
                                                                       Foreground="#8A97A6"
                                                                       Margin="8,5,0,0"
                                                                       IsHitTestVisible="False"
                                                                       HorizontalAlignment="Left"/>
                                                        </Grid>
                                                        <Button x:Name="SearchButton"
                                                                Content="&#xE721;"
                                                                Style="{StaticResource IconButtonStyle}"
                                                                Background="#1A73E8"
                                                                Width="30"
                                                                Height="30"
                                                                FontSize="14"
                                                                Click="SearchButton_Click"
                                                                Margin="2,0,0,0"
                                                                VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Border>
                                            </StackPanel>
                                            <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                                                <Button x:Name="ViewSelectedLogButton"
                                                        Content="View Log"
                                                        Style="{StaticResource RoundedButtonStyle}"
                                                        Background="#1A73E8"
                                                        Width="110"
                                                        Height="36"
                                                        Padding="14,6"
                                                        Margin="0,0,6,0"
                                                        Click="ViewSelectedLog_Click"/>
                                                <Button Content="Clear"
                                                        Style="{StaticResource RoundedButtonStyle}"
                                                        Background="#D9D9D9"
                                                        Foreground="#203244"
                                                        Width="100"
                                                        Height="36"
                                                        Padding="14,6"
                                                        Margin="0,0,4,0"
                                                        Click="ClearResults_Click"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                      <DataGrid x:Name="testResultsGrid"
                                              Grid.Row="1"
                                              AutoGenerateColumns="False"
                                              HeadersVisibility="Column"
                                              BorderThickness="0"
                                              SelectionMode="Extended"
                                              SelectionUnit="FullRow"
                                              SelectionChanged="DataGrid_SelectionChanged"
                                              PreviewMouseLeftButtonDown="DataGrid_CellPreviewMouseLeftButtonDown"
                                              VirtualizingPanel.VirtualizationMode="Recycling"
                                              VirtualizingPanel.ScrollUnit="Item">
                                        <DataGrid.Columns>
                                             <DataGridTemplateColumn Width="39.5">
                                                <DataGridTemplateColumn.Header>
                                                    <CheckBox Style="{StaticResource HeaderCheckBoxStyle}"
                                                              HorizontalAlignment="Center"
                                                              VerticalAlignment="Center"
                                                              Checked="SelectAllCheckBox_Checked"
                                                              Unchecked="SelectAllCheckBox_Unchecked"/>
                                                </DataGridTemplateColumn.Header>
                                                <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <CheckBox Style="{StaticResource RowCheckBoxStyle}"
                                                                  HorizontalAlignment="Center"
                                                                  VerticalAlignment="Center"
                                                                  IsChecked="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type DataGridRow}}, Path=IsSelected, Mode=OneWay}"
                                                                    PreviewMouseLeftButtonDown="RowCheckBox_PreviewMouseLeftButtonDown"
                                                                    Checked="RowCheckBox_Checked"
                                                                    Unchecked="RowCheckBox_Unchecked"/>
                                                     </DataTemplate>
                                                 </DataGridTemplateColumn.CellTemplate>
                                             </DataGridTemplateColumn>
                                             <DataGridTextColumn Header="Services" Binding="{Binding Service}" Width="2*" />
                                            <DataGridTextColumn Header="Server" Binding="{Binding Server}" Width="2*" />
                                            <DataGridTextColumn Header="Result" Binding="{Binding Result}" CellStyle="{StaticResource ResultCellStyle}" Width="Auto"/>
                                             <DataGridTextColumn Header="Message" Binding="{Binding Message}" Width="3*" />
                                         </DataGrid.Columns>
                                    </DataGrid>
                                </Grid>
                            </Border>
                        </Grid>
                    </Grid>
                </TabItem>

                <TabItem Header="Findings">
                    <Grid Margin="2">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0"
                                Background="{StaticResource SoftFillBrush}"
                                BorderBrush="{StaticResource PanelBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="14"
                                Padding="14"
                                Margin="0,0,0,12">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="320"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Search findings" FontWeight="Bold" Foreground="{StaticResource HeadingBrush}" Margin="0,0,0,6"/>
                                    <TextBox x:Name="FindingsSearchBox" Style="{StaticResource ModernTextBoxStyle}" TextChanged="FindingsSearchBox_TextChanged"/>
                                </StackPanel>

                                <TextBlock Grid.Column="1"
                                           Text="Actionable findings combine test failures, AD inventory drift, telemetry gaps, and privilege issues into one queue."
                                           Margin="18,26,20,0"
                                           Foreground="{StaticResource BodyBrush}"
                                           VerticalAlignment="Top"
                                           TextWrapping="Wrap"/>

                                <Border Grid.Column="2"
                                        Margin="8,20,8,0"
                                        Padding="12,8"
                                        Background="White"
                                        BorderBrush="{StaticResource PanelBorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="10"
                                        VerticalAlignment="Top">
                                    <StackPanel>
                                        <TextBlock Text="Open Findings" FontSize="11" Foreground="{StaticResource BodyBrush}" HorizontalAlignment="Center"/>
                                        <TextBlock x:Name="FindingsOpenCountText" Text="0" Margin="0,3,0,0" FontSize="18" FontWeight="Bold" Foreground="{StaticResource HeadingBrush}" HorizontalAlignment="Center"/>
                                    </StackPanel>
                                </Border>

                                <Border Grid.Column="3"
                                        Margin="0,20,8,0"
                                        Padding="12,8"
                                        Background="#FFF4E5"
                                        BorderBrush="#F2D3A0"
                                        BorderThickness="1"
                                        CornerRadius="10"
                                        VerticalAlignment="Top">
                                    <StackPanel>
                                        <TextBlock Text="High +" FontSize="11" Foreground="{StaticResource BodyBrush}" HorizontalAlignment="Center"/>
                                        <TextBlock x:Name="FindingsHighCountText" Text="0" Margin="0,3,0,0" FontSize="18" FontWeight="Bold" Foreground="#C45D00" HorizontalAlignment="Center"/>
                                    </StackPanel>
                                </Border>

                                <Border Grid.Column="4"
                                        Margin="0,20,0,0"
                                        Padding="12,8"
                                        Background="#FFEBEE"
                                        BorderBrush="#E8B8C1"
                                        BorderThickness="1"
                                        CornerRadius="10"
                                        VerticalAlignment="Top">
                                    <StackPanel>
                                        <TextBlock Text="Critical" FontSize="11" Foreground="{StaticResource BodyBrush}" HorizontalAlignment="Center"/>
                                        <TextBlock x:Name="FindingsCriticalCountText" Text="0" Margin="0,3,0,0" FontSize="18" FontWeight="Bold" Foreground="#C62828" HorizontalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </Border>

                        <Border Grid.Row="1"
                                Background="White"
                                BorderBrush="{StaticResource PanelBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="12">
                             <DataGrid x:Name="dgFindings"
                                      AutoGenerateColumns="False"
                                      BorderThickness="0"
                                      IsReadOnly="True"
                                      RowHeaderWidth="0"
                                      RowHeight="44"
                                      HeadersVisibility="Column"
                                      GridLinesVisibility="Horizontal"
                                      SelectionMode="Single"
                                      SelectionUnit="FullRow"
                                      AlternationCount="2"
                                      VirtualizingPanel.VirtualizationMode="Recycling"
                                      VirtualizingPanel.ScrollUnit="Item">
                                <DataGrid.Resources>
                                    <Style TargetType="DataGridRow" BasedOn="{StaticResource SelectableDataGridRowStyle}">
                                        <Style.Triggers>
                                            <Trigger Property="AlternationIndex" Value="1">
                                                <Setter Property="Background" Value="#F8FBFD"/>
                                            </Trigger>
                                            <DataTrigger Binding="{Binding Severity}" Value="Critical">
                                                <Setter Property="Background" Value="#FFF6F7"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Severity}" Value="High">
                                                <Setter Property="Background" Value="#FFFBF3"/>
                                            </DataTrigger>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter Property="Background" Value="#E3F0FF"/>
                                                <Setter Property="Foreground" Value="#13293D"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                    <Style TargetType="DataGridCell" BasedOn="{StaticResource SelectableDataGridCellStyle}">
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                        <Setter Property="Padding" Value="10,0"/>
                                    </Style>
                                </DataGrid.Resources>
                                <DataGrid.Columns>
                                    <DataGridTemplateColumn Header="Severity" Width="130">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding Severity}"
                                                           FontWeight="SemiBold"
                                                           FontSize="12"
                                                           VerticalAlignment="Center">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Foreground" Value="#607D8B"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Severity}" Value="Critical">
                                                                    <Setter Property="Foreground" Value="#C62828"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Severity}" Value="High">
                                                                    <Setter Property="Foreground" Value="#EF6C00"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Severity}" Value="Medium">
                                                                    <Setter Property="Foreground" Value="#F4A62A"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTextColumn Header="Category" Binding="{Binding Category}" Width="130" />
                                     <DataGridTextColumn Header="Target" Binding="{Binding Target}" Width="230">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="VerticalAlignment" Value="Center"/>
                                                <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                                                <Setter Property="ToolTip" Value="{Binding RelativeSource={RelativeSource Self}, Path=Text}"/>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>
                                    <DataGridTextColumn Header="Issue" Binding="{Binding Summary}" Width="1.15*">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="FontWeight" Value="SemiBold"/>
                                                <Setter Property="VerticalAlignment" Value="Center"/>
                                                <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                                                <Setter Property="ToolTip" Value="{Binding RelativeSource={RelativeSource Self}, Path=Text}"/>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>
                                    <DataGridTextColumn Header="Recommended Action" Binding="{Binding Remediation}" Width="1.2*">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="VerticalAlignment" Value="Center"/>
                                                <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                                                <Setter Property="ToolTip" Value="{Binding RelativeSource={RelativeSource Self}, Path=Text}"/>
                                                <Setter Property="Foreground" Value="{StaticResource BodyBrush}"/>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>
                                    <DataGridTextColumn Header="Source" Binding="{Binding Source}" Width="170">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="VerticalAlignment" Value="Center"/>
                                                <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                                                <Setter Property="ToolTip" Value="{Binding RelativeSource={RelativeSource Self}, Path=Text}"/>
                                                <Setter Property="Foreground" Value="{StaticResource BodyBrush}"/>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Border>
                    </Grid>
                </TabItem>

                <TabItem Header="Infrastructure">
                    <Grid Margin="2">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0" Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Background="White" BorderBrush="{StaticResource PanelBorderBrush}" BorderThickness="1" CornerRadius="14" Padding="16" Margin="0,0,6,0">
                                <StackPanel>
                                    <TextBlock Text="Forest" FontSize="12" Foreground="{StaticResource BodyBrush}"/>
