<Window x:Class="AdHealthMonitor.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="AD Guardian"
        Height="820"
        Width="1320"
        MinHeight="600"
        MinWidth="960"
        Background="#EEF3F8"
        WindowStartupLocation="CenterScreen">

    <!-- Resources moved to App.xaml -->

    <Grid Background="#EDF2F7">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0"
                x:Name="SidebarPanel"
                Width="220"
                Background="{StaticResource SidebarBgBrush}"
                BorderBrush="#0E1218"
                BorderThickness="0,0,1,0">
            <Grid Margin="14">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Grid Margin="0,0,0,14">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="1"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="1"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0"
                            Background="#40FFFFFF"
                            Margin="-18,0"/>

                    <Grid Grid.Row="1" Margin="0,10,0,10">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" x:Name="SidebarHeaderContent">
                            <Image x:Name="SidebarLogo" Width="24" Height="24" VerticalAlignment="Center" Margin="0,0,10,0">
                                <Image.Source>
                                    <BitmapImage UriSource="pack://application:,,,/AD-Guardian-logo-_2_.ico" DecodePixelWidth="24" DecodePixelHeight="24" CacheOption="OnLoad"/>
                                </Image.Source>
                            </Image>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock x:Name="SidebarTitleText"
                                           Text="AD Guardian"
                                           FontSize="18"
                                           FontWeight="Bold"
                                           Foreground="White"/>
                                <TextBlock x:Name="SidebarSubtitleText"
                                           Text="Operator Console"
                                           Margin="0,2,0,0"
                                           FontSize="10"
                                           Foreground="#B8D4FF"/>
                            </StackPanel>
                        </StackPanel>
                        <ToggleButton x:Name="SidebarToggleButton"
                                      HorizontalAlignment="Right"
                                      VerticalAlignment="Center"
                                      Click="SidebarToggleButton_Click"
                                      Background="Transparent"
                                      BorderThickness="0"
                                      Padding="0"
                                      Margin="8,0,0,0"
                                      Cursor="Hand"
                                      ToolTip="Collapse sidebar">
                            <ToggleButton.Style>
                                <Style TargetType="ToggleButton">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="ToggleButton">
                                                <Border x:Name="RootBorder"
                                                        Width="34"
                                                        Height="18"
                                                        CornerRadius="9"
                                                        Background="#16314D"
                                                        BorderBrush="#4A6C94"
                                                        BorderThickness="1"
                                                        Padding="0">
                                                    <Grid>
                                                        <Border x:Name="ActiveThumb"
                                                                Width="12"
                                                                Height="12"
                                                                Margin="2"
                                                                CornerRadius="6"
                                                                HorizontalAlignment="Right"
                                                                VerticalAlignment="Center"
                                                                Background="White"/>
                                                    </Grid>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="RootBorder" Property="Background" Value="#1D3E60"/>
                                                        <Setter TargetName="RootBorder" Property="BorderBrush" Value="#6F8FB5"/>
                                                    </Trigger>
                                                    <Trigger Property="IsChecked" Value="True">
                                                        <Setter TargetName="ActiveThumb" Property="HorizontalAlignment" Value="Left"/>
                                                        <Setter TargetName="RootBorder" Property="Background" Value="#101A26"/>
                                                        <Setter TargetName="RootBorder" Property="BorderBrush" Value="#38526E"/>
                                                        <Setter TargetName="ActiveThumb" Property="Background" Value="#C9D6E5"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </ToggleButton.Style>
                        </ToggleButton>
                    </Grid>

                    <Border Grid.Row="2"
                            Background="#40FFFFFF"
                            Margin="-18,0"/>
                </Grid>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <StackPanel>
                        <Button x:Name="HomeNavButton" Tag="0" Click="NavSectionButton_Click" Style="{StaticResource SidebarNavButtonStyle}" Margin="0,0,0,6"><StackPanel Orientation="Horizontal"><TextBlock Text="&#xE80F;" FontFamily="Segoe MDL2 Assets" Margin="0,0,10,0"/><TextBlock x:Name="HomeNavLabel" Text="Home"/></StackPanel></Button>

                        <ToggleButton x:Name="MonitoringToggle" Click="GroupToggle_Click" Tag="MonitoringPanel" Style="{StaticResource SidebarSectionButtonStyle}" Margin="0,0,0,2" IsChecked="True"><StackPanel Orientation="Horizontal"><TextBlock Text="&#xE9D9;" FontFamily="Segoe MDL2 Assets" FontSize="13" Margin="0,0,8,0"/><TextBlock x:Name="MonitoringNavLabel" Text="MONITORING"/><TextBlock x:Name="MonitoringArrow" Text="&#xE70D;" FontFamily="Segoe MDL2 Assets" FontSize="10" Margin="6,2,0,0"/></StackPanel></ToggleButton>
                        <StackPanel x:Name="MonitoringPanel" Margin="12,0,0,6" ClipToBounds="True">
                            <Button x:Name="HealthNavButton" Tag="1" Click="NavSectionButton_Click" Style="{StaticResource SidebarNavButtonStyle}" Margin="0,0,0,4"><StackPanel Orientation="Horizontal"><TextBlock Text="•" Margin="0,0,10,0" FontSize="12"/><TextBlock x:Name="HealthNavLabel" Text="Health"/></StackPanel></Button>
                            <Button x:Name="FindingsNavButton" Tag="2" Click="NavSectionButton_Click" Style="{StaticResource SidebarNavButtonStyle}" Margin="0,0,0,4"><StackPanel Orientation="Horizontal"><TextBlock Text="•" Margin="0,0,10,0" FontSize="12"/><TextBlock x:Name="FindingsNavLabel" Text="Findings"/></StackPanel></Button>
                            <Button x:Name="SecurityNavButton" Tag="6" Click="NavSectionButton_Click" Style="{StaticResource SidebarNavButtonStyle}" Margin="0,0,0,4"><StackPanel Orientation="Horizontal"><TextBlock Text="•" Margin="0,0,10,0" FontSize="12"/><TextBlock x:Name="SecurityNavLabel" Text="Security"/></StackPanel></Button>
                        </StackPanel>

                        <ToggleButton x:Name="DataToggle" Click="GroupToggle_Click" Tag="DataPanel" Style="{StaticResource SidebarSectionButtonStyle}" Margin="0,0,0,2" IsChecked="True"><StackPanel Orientation="Horizontal"><TextBlock Text="&#xE968;" FontFamily="Segoe MDL2 Assets" FontSize="13" Margin="0,0,8,0"/><TextBlock x:Name="DataNavLabel" Text="DATA"/><TextBlock x:Name="DataArrow" Text="&#xE70D;" FontFamily="Segoe MDL2 Assets" FontSize="10" Margin="6,2,0,0"/></StackPanel></ToggleButton>
                        <StackPanel x:Name="DataPanel" Margin="12,0,0,6" ClipToBounds="True">
                            <Button x:Name="InfrastructureNavButton" Tag="3" Click="NavSectionButton_Click" Style="{StaticResource SidebarNavButtonStyle}" Margin="0,0,0,4"><StackPanel Orientation="Horizontal"><TextBlock Text="•" Margin="0,0,10,0" FontSize="12"/><TextBlock x:Name="InfrastructureNavLabel" Text="Infrastructure"/></StackPanel></Button>
                            <Button x:Name="HistoryNavButton" Tag="4" Click="NavSectionButton_Click" Style="{StaticResource SidebarNavButtonStyle}" Margin="0,0,0,4"><StackPanel Orientation="Horizontal"><TextBlock Text="•" Margin="0,0,10,0" FontSize="12"/><TextBlock x:Name="HistoryNavLabel" Text="History"/></StackPanel></Button>
                            <Button x:Name="LogsNavButton" Tag="5" Click="NavSectionButton_Click" Style="{StaticResource SidebarNavButtonStyle}" Margin="0,0,0,4"><StackPanel Orientation="Horizontal"><TextBlock Text="•" Margin="0,0,10,0" FontSize="12"/><TextBlock x:Name="LogsNavLabel" Text="Logs"/></StackPanel></Button>
                        </StackPanel>

                        <Rectangle Height="1" Fill="#2A3644" Margin="8,4,8,8"/>

                        <Button x:Name="SettingsNavButton" Tag="7" Click="NavSectionButton_Click" Style="{StaticResource SidebarNavButtonStyle}" Margin="0,0,0,6"><StackPanel Orientation="Horizontal"><TextBlock Text="&#xE713;" FontFamily="Segoe MDL2 Assets" Margin="0,0,10,0"/><TextBlock x:Name="SettingsNavLabel" Text="Settings"/></StackPanel></Button>
                        <Button x:Name="SchedulerNavButton" Tag="8" Click="NavSectionButton_Click" Style="{StaticResource SidebarNavButtonStyle}" Margin="0,0,0,6"><StackPanel Orientation="Horizontal"><TextBlock Text="&#xE823;" FontFamily="Segoe MDL2 Assets" Margin="0,0,10,0"/><TextBlock x:Name="SchedulerNavLabel" Text="Scheduler"/></StackPanel></Button>
                        <Button Click="AboutButton_Click" Style="{StaticResource SidebarNavButtonStyle}" Margin="0,0,0,6"><StackPanel Orientation="Horizontal"><TextBlock Text="&#xE946;" FontFamily="Segoe MDL2 Assets" Margin="0,0,10,0"/><TextBlock Text="About"/></StackPanel></Button>
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Border>

        <Grid Grid.Column="1" Margin="18">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="White"
                BorderBrush="{StaticResource PanelBorderBrush}"
                BorderThickness="1"
                CornerRadius="16"
                Padding="16,12"
                Margin="0,0,0,16">
            <StackPanel Orientation="Horizontal">
                <Border Background="{StaticResource SoftFillBrush}"
                        CornerRadius="10"
                        Width="40"
                        Height="40"
                        Margin="0,0,14,0">
                    <TextBlock x:Name="WorkspaceSectionIconText"
                               Text="&#xE9D9;"
                               FontFamily="Segoe MDL2 Assets"
                               FontSize="22"
                               Foreground="{StaticResource SidebarActiveBrush}"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                </Border>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock x:Name="WorkspaceSectionTitleText"
                               Text="Health"
                               FontSize="22"
                               FontWeight="Bold"
                               Foreground="{StaticResource HeadingBrush}"/>
                    <TextBlock x:Name="WorkspaceSectionSubtitleText"
                               Text="Domain controller health overview"
                               FontSize="12"
                               Foreground="{StaticResource BodyBrush}"
                               Margin="0,2,0,0"/>
            </StackPanel>
        </StackPanel>
    </Border>

        <Border x:Name="ProgressPanel"
                Grid.Row="1"
                Visibility="Collapsed"
                Background="#FFFFFF"
                BorderBrush="#CFE0F1"
                BorderThickness="1"
                CornerRadius="14"
                Padding="16,12"
                Margin="0,0,0,16">
            <Border.Effect>
                <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.12" Color="Black"/>
            </Border.Effect>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Border Grid.RowSpan="2"
                        Grid.Column="0"
                        Width="44"
                        Height="44"
                        Margin="0,0,14,0"
                        Background="#F4F8FC"
                        BorderBrush="#D9E6F2"
                        BorderThickness="1"
                        CornerRadius="12"
                        VerticalAlignment="Center">
                    <TextBlock x:Name="RunProgressPercentText"
                               Text="0%"
                               FontSize="15"
                               FontWeight="Bold"
                               Foreground="{StaticResource AccentBlueBrush}"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                </Border>

                <StackPanel Grid.Row="0" Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock x:Name="RunProgressTitleText"
                               Text="Running domain controller diagnostics"
                               FontSize="14"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource HeadingBrush}"/>
                    <TextBlock x:Name="RunProgressDetailText"
                               Text="Preparing to run diagnostics."
                               Margin="0,3,0,0"
                               FontSize="12"
                               Foreground="{StaticResource BodyBrush}"
                               TextWrapping="Wrap"
                               TextTrimming="CharacterEllipsis"/>
                </StackPanel>

                <TextBlock x:Name="RunProgressCountText"
                           Grid.Row="0"
                           Grid.Column="2"
                           Text="0 / 0 steps"
                           Margin="16,0,0,0"
                           VerticalAlignment="Center"
                           FontSize="12"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource HeadingBrush}"/>

                <ProgressBar x:Name="TestProgressBar"
                             Grid.Row="1"
                             Grid.Column="1"
                             Grid.ColumnSpan="2"
                             Margin="0,8,0,0"
                             Height="10"
                             Style="{StaticResource ModernProgressBarStyle}"
                             Minimum="0"
                             Maximum="100"
                             Value="0"/>
            </Grid>
        </Border>

        <Border Grid.Row="2"
                Background="{StaticResource PanelFillBrush}"
                Padding="24"
                Margin="0,0,0,0"
                BorderBrush="{StaticResource PanelBorderBrush}"
                BorderThickness="1"
                CornerRadius="18">
            <TabControl x:Name="MainTabControl"
                        SelectedIndex="0"
                        Margin="0"
                        BorderThickness="0"
                        Background="Transparent"
                        Style="{StaticResource PageHostTabControlStyle}"
                        SelectionChanged="MainTabControl_SelectionChanged"
                        Loaded="MainTabControl_Loaded">
                <TabControl.Resources>
                    <Style TargetType="TabItem" BasedOn="{StaticResource ModernTabItemStyle}"/>
                </TabControl.Resources>
                <TabItem Header="Home">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                        <Grid Margin="2">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <Border Grid.Row="0"
                                    Background="White"
                                    BorderBrush="{StaticResource PanelBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="14"
                                    Padding="16,14"
                                    Margin="0,0,0,14">
                                <StackPanel>
                                    <TextBlock Text="Welcome to AD Guardian"
                                               FontSize="20"
                                               FontWeight="Bold"
                                               Foreground="{StaticResource HeadingBrush}"/>
                                    <TextBlock Text="Monitor, diagnose, and report on your Active Directory health."
                                               Margin="0,4,0,0"
                                               Foreground="{StaticResource BodyBrush}"/>
                                </StackPanel>
                            </Border>

                            <Grid Grid.Row="1" Margin="0,0,0,14">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <Grid Grid.Column="0" Margin="0,0,10,0">
                                    <Border Background="Black"
                                            CornerRadius="14"
                                            Opacity="0"
                                            IsHitTestVisible="False"/>
                                    <Border Background="White"
                                            BorderBrush="{StaticResource PanelBorderBrush}"
                                            BorderThickness="1"
                                            CornerRadius="14"
                                            Padding="16"
                                            Cursor="Hand"
                                            MouseDown="HomeRunTests_Click"
                                            MouseEnter="HomeCard_MouseEnter"
                                            MouseLeave="HomeCard_MouseLeave">
                                        <StackPanel VerticalAlignment="Center">
                                            <TextBlock Text="&#xE768;" FontFamily="Segoe MDL2 Assets" FontSize="32" Foreground="{StaticResource AccentGreenBrush}"/>
                                            <TextBlock Text="Run Tests"
                                                       FontSize="16"
                                                       FontWeight="SemiBold"
                                                       Foreground="{StaticResource HeadingBrush}"
                                                       Margin="0,12,0,0"/>
                                            <TextBlock Text="Execute health checks across your domain controllers."
                                                       Margin="0,6,0,0"
                                                       Foreground="{StaticResource BodyBrush}"
                                                       TextWrapping="Wrap"/>
                                        </StackPanel>
                                    </Border>
                                </Grid>

                                <Grid Grid.Column="1" Margin="5,0">
                                    <Border Background="Black"
                                            CornerRadius="14"
                                            Opacity="0"
                                            IsHitTestVisible="False"/>
                                    <Border Background="White"
                                            BorderBrush="{StaticResource PanelBorderBrush}"
                                            BorderThickness="1"
                                            CornerRadius="14"
                                            Padding="16"
                                            Cursor="Hand"
                                            MouseDown="HomeViewFindings_Click"
                                            MouseEnter="HomeCard_MouseEnter"
                                            MouseLeave="HomeCard_MouseLeave">
                                        <StackPanel VerticalAlignment="Center">
                                            <TextBlock Text="&#xE9D2;" FontFamily="Segoe MDL2 Assets" FontSize="32" Foreground="{StaticResource AccentRedBrush}"/>
                                            <TextBlock Text="View Findings"
                                                       FontSize="16"
                                                       FontWeight="SemiBold"
                                                       Foreground="{StaticResource HeadingBrush}"
                                                       Margin="0,12,0,0"/>
                                            <TextBlock Text="Review critical issues and remediation guidance."
                                                       Margin="0,6,0,0"
                                                       Foreground="{StaticResource BodyBrush}"
                                                       TextWrapping="Wrap"/>
                                        </StackPanel>
                                    </Border>
                                </Grid>

                                <Grid Grid.Column="2" Margin="10,0,0,0">
                                    <Border Background="Black"
                                            CornerRadius="14"
                                            Opacity="0"
                                            IsHitTestVisible="False"/>
                                    <Border Background="White"
                                            BorderBrush="{StaticResource PanelBorderBrush}"
                                            BorderThickness="1"
                                            CornerRadius="14"
                                            Padding="16"
                                            Cursor="Hand"
                                            MouseDown="HomeViewHistory_Click"
                                            MouseEnter="HomeCard_MouseEnter"
                                            MouseLeave="HomeCard_MouseLeave">
                                        <StackPanel VerticalAlignment="Center">
                                            <TextBlock Text="&#xE81C;" FontFamily="Segoe MDL2 Assets" FontSize="32" Foreground="{StaticResource SidebarActiveBrush}"/>
                                            <TextBlock Text="History"
                                                       FontSize="16"
                                                       FontWeight="SemiBold"
                                                       Foreground="{StaticResource HeadingBrush}"
                                                       Margin="0,12,0,0"/>
                                            <TextBlock Text="Browse past runs and compare results over time."
                                                       Margin="0,6,0,0"
                                                       Foreground="{StaticResource BodyBrush}"
                                                       TextWrapping="Wrap"/>
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </Grid>

                            <Grid Grid.Row="2" Margin="0,0,0,14">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" Background="White" BorderBrush="{StaticResource PanelBorderBrush}" BorderThickness="1" CornerRadius="14" Padding="16" Margin="0,0,6,0">
                                    <StackPanel>
                                        <TextBlock Text="Health Score" Foreground="{StaticResource BodyBrush}" FontSize="12"/>
                                        <TextBlock x:Name="HomeHealthScoreText" Text="--" FontSize="28" FontWeight="Bold" Foreground="{StaticResource HeadingBrush}" Margin="0,4,0,0"/>
                                    </StackPanel>
                                </Border>
                                <Border Grid.Column="1" Background="White" BorderBrush="{StaticResource PanelBorderBrush}" BorderThickness="1" CornerRadius="14" Padding="16" Margin="6,0">
                                    <StackPanel>
                                        <TextBlock Text="Critical" Foreground="{StaticResource BodyBrush}" FontSize="12"/>
                                        <TextBlock x:Name="HomeCriticalText" Text="--" FontSize="28" FontWeight="Bold" Foreground="#D32F2F" Margin="0,4,0,0"/>
                                    </StackPanel>
                                </Border>
                                <Border Grid.Column="2" Background="White" BorderBrush="{StaticResource PanelBorderBrush}" BorderThickness="1" CornerRadius="14" Padding="16" Margin="6,0">
                                    <StackPanel>
                                        <TextBlock Text="Passing" Foreground="{StaticResource BodyBrush}" FontSize="12"/>
                                        <TextBlock x:Name="HomePassingText" Text="--" FontSize="28" FontWeight="Bold" Foreground="#2E7D32" Margin="0,4,0,0"/>
                                    </StackPanel>
                                </Border>
                                <Border Grid.Column="3" Background="White" BorderBrush="{StaticResource PanelBorderBrush}" BorderThickness="1" CornerRadius="14" Padding="16" Margin="6,0">
                                    <StackPanel>
                                        <TextBlock Text="Pass Rate" Foreground="{StaticResource BodyBrush}" FontSize="12"/>
                                        <TextBlock x:Name="HomePassRateText" Text="--" FontSize="28" FontWeight="Bold" Foreground="{StaticResource SidebarActiveBrush}" Margin="0,4,0,0"/>
                                    </StackPanel>
                                </Border>
                                <Border Grid.Column="4" Background="White" BorderBrush="{StaticResource PanelBorderBrush}" BorderThickness="1" CornerRadius="14" Padding="16" Margin="6,0">
                                    <StackPanel>
                                        <TextBlock Text="Total Runs" Foreground="{StaticResource BodyBrush}" FontSize="12"/>
                                        <TextBlock x:Name="HomeTotalRunsText" Text="--" FontSize="28" FontWeight="Bold" Foreground="{StaticResource HeadingBrush}" Margin="0,4,0,0"/>
                                    </StackPanel>
                                </Border>
                                <Border Grid.Column="5" Background="White" BorderBrush="{StaticResource PanelBorderBrush}" BorderThickness="1" CornerRadius="14" Padding="16" Margin="6,0,0,0">
                                    <StackPanel>
                                        <TextBlock Text="Last Run" Foreground="{StaticResource BodyBrush}" FontSize="12"/>
                                        <TextBlock x:Name="HomeLastRunText" Text="No runs yet" FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource HeadingBrush}" Margin="0,4,0,0" TextWrapping="WrapWithOverflow" TextTrimming="CharacterEllipsis" MaxHeight="40"/>
                                    </StackPanel>
                                </Border>
                            </Grid>

                            <Grid Grid.Row="3" Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <Border Grid.Column="0"
                                        Background="White"
                                        BorderBrush="{StaticResource PanelBorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="14"
                                        Padding="16"
                                        Margin="0,0,7,0">
                                    <StackPanel>
                                        <TextBlock Text="Run History"
                                                   FontSize="14"
                                                   FontWeight="SemiBold"
                                                   Foreground="{StaticResource HeadingBrush}"
                                                   Margin="0,0,0,10"/>
                                        <StackPanel x:Name="HomeRunHistoryBars"
                                                    Orientation="Horizontal"
                                                    HorizontalAlignment="Center"
                                                    Height="100">
                                            <TextBlock Text="No data" Foreground="{StaticResource BodyBrush}" FontSize="12" VerticalAlignment="Center"/>
                                        </StackPanel>
                                        <TextBlock Text="Pass / Fail per run (last 6)"
                                                   FontSize="11"
                                                   Foreground="{StaticResource BodyBrush}"
                                                   Margin="0,8,0,0"
                                                   HorizontalAlignment="Center"/>
                                    </StackPanel>
                                </Border>

                                <Border Grid.Column="1"
                                        Background="White"
                                        BorderBrush="{StaticResource PanelBorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="14"
                                        Padding="16"
                                        Margin="7,0,7,0">
                                    <StackPanel>
                                        <TextBlock Text="Pass Rate Trend"
                                                   FontSize="14"
                                                   FontWeight="SemiBold"
                                                   Foreground="{StaticResource HeadingBrush}"
                                                   Margin="0,0,0,10"/>
                                        <Border Background="#F5F8FC"
                                                CornerRadius="8"
                                                Padding="6"
                                                Height="100">
                                            <Viewbox Stretch="Fill">
                                                <Canvas x:Name="HomeTrendCanvas" Width="120" Height="60">
                                                    <Polyline x:Name="HomeTrendPolyline"
                                                              Stroke="{StaticResource SidebarActiveBrush}"
                                                              StrokeThickness="2"
                                                              StrokeLineJoin="Round"/>
                                                </Canvas>
                                            </Viewbox>
                                        </Border>
                                    </StackPanel>
                                </Border>

                                <Border Grid.Column="2"
                                        Background="White"
                                        BorderBrush="{StaticResource PanelBorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="14"
                                        Padding="16"
                                        Margin="7,0,0,0">
                                    <StackPanel>
                                        <TextBlock Text="Findings Summary"
                                                   FontSize="14"
                                                   FontWeight="SemiBold"
                                                   Foreground="{StaticResource HeadingBrush}"
                                                   Margin="0,0,0,10"/>
                                        <StackPanel x:Name="HomeFindingsSummary">
                                            <TextBlock Text="No findings" Foreground="{StaticResource BodyBrush}" FontSize="12"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </Grid>
                    </ScrollViewer>
                </TabItem>
                <TabItem Header="Health">
                        <ContentControl x:Name="HealthTabHost" />
                </TabItem>

                <TabItem Header="Findings">
                        <ContentControl x:Name="FindingsTabHost" />
                </TabItem>

                <TabItem Header="Infrastructure">
                        <ContentControl x:Name="InfrastructureTabHost" />
                </TabItem>

                <TabItem Header="History">
                        <ContentControl x:Name="HistoryTabHost" />
                </TabItem>

                <TabItem Header="Logs">
                        <ContentControl x:Name="LogsTabHost" />
                </TabItem>

                <TabItem Header="Security">
                        <ContentControl x:Name="SecurityTabHost" />
                </TabItem>
                <TabItem Header="Settings">
                        <ContentControl x:Name="SettingsTabHost" />
                </TabItem>
                <TabItem Header="Scheduler">
                        <ContentControl x:Name="SchedulerTabHost" />
                </TabItem>
            </TabControl>
        </Border>
        </Grid>
    </Grid>
</Window>
