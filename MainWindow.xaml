                                        Height="40"
                                        Margin="6,0,6,0"
                                        VerticalAlignment="Bottom"
                                        IsEnabled="False"
                                        Click="ViewSelectedHistoryRun_Click"/>

                                <Button Grid.Column="5"
                                        Content="Delete Selected"
                                        Style="{StaticResource RoundedButtonStyle}"
                                        Background="#D32F2F"
                                        Width="134"
                                        Height="40"
                                        Margin="6,0,6,0"
                                        VerticalAlignment="Bottom"
                                        Click="DeleteSelectedHistory_Click"/>

                                <Button Grid.Column="6"
                                        x:Name="CompareRunsButton"
                                        Content="Compare Runs"
                                        Style="{StaticResource RoundedButtonStyle}"
                                        Background="#1A73E8"
                                        Width="134"
                                        Height="40"
                                        VerticalAlignment="Bottom"
                                        IsEnabled="False"
                                        Click="CompareRuns_Click"/>
                            </Grid>
                        </Border>

                        <Border Grid.Row="1"
                                Background="White"
                                BorderBrush="{StaticResource PanelBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="12">
                            <DataGrid x:Name="dgTestHistory"
                                      AutoGenerateColumns="False"
                                      BorderThickness="0"
                                      CanUserAddRows="False"
                                      CanUserDeleteRows="False"
                                      IsReadOnly="True"
                                      RowHeaderWidth="0"
                                      RowHeight="44"
                                      HeadersVisibility="Column"
                                      GridLinesVisibility="Horizontal"
                                      SelectionMode="Extended"
                                      SelectionUnit="FullRow"
                                      AlternationCount="2"
                                      VirtualizingPanel.VirtualizationMode="Recycling"
                                       VirtualizingPanel.ScrollUnit="Item"
                                       PreviewMouseLeftButtonDown="DataGrid_CellPreviewMouseLeftButtonDown"
                                       SelectionChanged="dgTestHistory_SelectionChanged">
                                 <DataGrid.Resources>
                                     <Style TargetType="DataGridCell">
                                         <Setter Property="VerticalContentAlignment" Value="Center"/>
                                         <Setter Property="Padding" Value="8,0"/>
                                     </Style>
                                 </DataGrid.Resources>
                                 <DataGrid.Columns>
                                      <DataGridTemplateColumn Width="36">
                                          <DataGridTemplateColumn.Header>
                                              <CheckBox Style="{StaticResource HeaderCheckBoxStyle}"
                                                        HorizontalAlignment="Center"
                                                        VerticalAlignment="Center"
                                                        Checked="SelectAllCheckBox_Checked"
                                                        Unchecked="SelectAllCheckBox_Unchecked"/>
                                          </DataGridTemplateColumn.Header>
                                          <DataGridTemplateColumn.CellTemplate>
                                              <DataTemplate>
                                                  <Grid VerticalAlignment="Center">
                                                       <CheckBox Style="{StaticResource RowCheckBoxStyle}"
                                                                 HorizontalAlignment="Center"
                                                                 VerticalAlignment="Center"
                                                                 IsChecked="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type DataGridRow}}, Path=IsSelected, Mode=OneWay}"
                                                                        PreviewMouseLeftButtonDown="RowCheckBox_PreviewMouseLeftButtonDown"
                                                                        Checked="RowCheckBox_Checked"
                                                                        Unchecked="RowCheckBox_Unchecked"/>
                                                   </Grid>
                                               </DataTemplate>
                                          </DataGridTemplateColumn.CellTemplate>
                                      </DataGridTemplateColumn>
                                     <DataGridTextColumn Header="Run Date" Binding="{Binding RunDate, StringFormat={}{0:dd MMM yyyy HH:mm}}" Width="170">
                                         <DataGridTextColumn.ElementStyle>
                                             <Style TargetType="TextBlock">
                                                 <Setter Property="VerticalAlignment" Value="Center"/>
                                             </Style>
                                         </DataGridTextColumn.ElementStyle>
                                     </DataGridTextColumn>
                                    <DataGridTextColumn Header="Run Type" Binding="{Binding TestType}" Width="130">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="VerticalAlignment" Value="Center"/>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>
                                    <DataGridTextColumn Header="Total" Binding="{Binding Total}" Width="70">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="HorizontalAlignment" Value="Center"/>
                                                <Setter Property="VerticalAlignment" Value="Center"/>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>
                                    <DataGridTextColumn Header="Passed" Binding="{Binding Passed}" Width="78">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="HorizontalAlignment" Value="Center"/>
                                                <Setter Property="VerticalAlignment" Value="Center"/>
                                                <Setter Property="Foreground" Value="#2E7D32"/>
                                                <Setter Property="FontWeight" Value="SemiBold"/>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>
                                    <DataGridTextColumn Header="Failed" Binding="{Binding Failed}" Width="78">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="HorizontalAlignment" Value="Center"/>
                                                <Setter Property="VerticalAlignment" Value="Center"/>
                                                <Setter Property="Foreground" Value="#C62828"/>
                                                <Setter Property="FontWeight" Value="SemiBold"/>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>
                                    <DataGridTextColumn Header="Summary" Binding="{Binding Details}" Width="*">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="TextWrapping" Value="Wrap"/>
                                                <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                                                <Setter Property="VerticalAlignment" Value="Center"/>
                                                <Setter Property="MaxHeight" Value="36"/>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Border>
                    </Grid>
                </TabItem>

                <TabItem Header="Logs">
                    <Grid Margin="2">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0"
                                Background="{StaticResource SoftFillBrush}"
                                BorderBrush="{StaticResource PanelBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="14"
                                Padding="16"
                                Margin="0,0,0,12">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="220"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="Logs Workspace"
                                               FontSize="16"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource HeadingBrush}"/>
                                    <TextBlock x:Name="LogsSummaryText"
                                               Text="Browse failures, jump to exact evidence, and inspect the raw combined log."
                                               Margin="0,4,0,0"
                                               Foreground="{StaticResource BodyBrush}"
                                               TextWrapping="Wrap"/>
                                </StackPanel>
                                <ComboBox x:Name="LogsDcFilter"
                                          Grid.Column="1"
                                          Width="160"
                                          Height="36"
                                          Margin="16,0,8,0"
                                          VerticalAlignment="Center"
                                          SelectionChanged="LogsFilter_Changed"/>
                                <ComboBox x:Name="LogsResultFilter"
                                          Grid.Column="2"
                                          Width="120"
                                          Height="36"
                                          Margin="0,0,8,0"
                                          VerticalAlignment="Center"
                                          SelectionChanged="LogsFilter_Changed">
                                    <ComboBoxItem Content="All Results" IsSelected="True"/>
                                    <ComboBoxItem Content="Failures"/>
                                    <ComboBoxItem Content="Passes"/>
                                </ComboBox>
                                <TextBox x:Name="LogsSearchBox"
                                         Grid.Column="3"
                                         Style="{StaticResource ModernTextBoxStyle}"
                                         VerticalAlignment="Center"
                                         TextChanged="LogsSearchBox_TextChanged"/>
                                <Button Grid.Column="4"
                                        Content="Clear"
                                        Style="{StaticResource RoundedButtonStyle}"
                                        Background="#607D8B"
                                        Width="96"
                                        Height="38"
                                        Margin="8,0,0,0"
                                        VerticalAlignment="Center"
                                        Click="ClearLogsFilters_Click"/>
                                <Button Grid.Column="5"
                                        Content="Open Log..."
                                        Style="{StaticResource RoundedButtonStyle}"
                                        Background="#1A73E8"
                                        Width="110"
                                        Height="38"
                                        Margin="8,0,0,0"
                                        VerticalAlignment="Center"
                                        Click="OpenLogFile_Click"/>
                            </Grid>
                        </Border>

                        <Border Grid.Row="1"
                                Background="White"
                                BorderBrush="{StaticResource PanelBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="12"
                                Padding="14"
                                Margin="0,0,0,12">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Border Background="#FFF6F7"
                                        BorderBrush="#E8B8C1"
                                        BorderThickness="1"
                                        CornerRadius="10"
                                        Padding="12,8"
                                        Margin="0,0,8,0">
                                    <StackPanel>
                                        <TextBlock Text="Visible Entries" FontSize="11" Foreground="{StaticResource BodyBrush}" HorizontalAlignment="Center"/>
                                        <TextBlock x:Name="LogsVisibleCountText" Text="0" Margin="0,3,0,0" FontSize="18" FontWeight="Bold" Foreground="{StaticResource HeadingBrush}" HorizontalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                                <Border Grid.Column="1"
                                        Background="#FFEBEE"
                                        BorderBrush="#E8B8C1"
                                        BorderThickness="1"
                                        CornerRadius="10"
                                        Padding="12,8"
                                        Margin="0,0,8,0">
                                    <StackPanel>
                                        <TextBlock Text="Failures" FontSize="11" Foreground="{StaticResource BodyBrush}" HorizontalAlignment="Center"/>
                                        <TextBlock x:Name="LogsFailureCountText" Text="0" Margin="0,3,0,0" FontSize="18" FontWeight="Bold" Foreground="#C62828" HorizontalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                                <Border Grid.Column="2"
                                        Background="#E8F5E9"
                                        BorderBrush="#B8DDBB"
                                        BorderThickness="1"
                                        CornerRadius="10"
                                        Padding="12,8"
                                        Margin="0,0,8,0">
                                    <StackPanel>
                                        <TextBlock Text="Passes" FontSize="11" Foreground="{StaticResource BodyBrush}" HorizontalAlignment="Center"/>
                                        <TextBlock x:Name="LogsPassCountText" Text="0" Margin="0,3,0,0" FontSize="18" FontWeight="Bold" Foreground="#2E7D32" HorizontalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                                <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center"/>
                            </Grid>
                        </Border>

                        <Grid Grid.Row="2" Margin="0,0,0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1.2*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="1.6*"/>
                            </Grid.ColumnDefinitions>

                            <GridSplitter Grid.Column="1"
                                          Width="4"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Stretch"
                                          Background="#D9E4EF"
                                          ShowsPreview="True"
                                          ResizeDirection="Columns"/>

                            <Border Grid.Column="0"
                                    Background="White"
                                    BorderBrush="{StaticResource PanelBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="12"
                                    Padding="0"
                                    Margin="0,0,8,0">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>
                                    <Border Background="{StaticResource SoftFillBrush}"
                                            BorderBrush="{StaticResource PanelBorderBrush}"
                                            BorderThickness="0,0,0,1"
                                            CornerRadius="12,12,0,0"
                                            Padding="12,10">
                                        <TextBlock Text="Log Sections"
                                                   FontSize="14"
                                                   FontWeight="SemiBold"
                                                   Foreground="{StaticResource HeadingBrush}"/>
                                    </Border>
                                    <DataGrid Grid.Row="1"
                                              x:Name="dgLogsEntries"
                                              AutoGenerateColumns="False"
                                              BorderThickness="0"
                                              IsReadOnly="True"
                                              RowHeaderWidth="0"
                                              RowHeight="46"
                                              HeadersVisibility="Column"
                                              GridLinesVisibility="Horizontal"
                                              SelectionMode="Single"
                                              SelectionUnit="FullRow"
                                              AlternationCount="2"
                                              VirtualizingPanel.VirtualizationMode="Recycling"
                                              VirtualizingPanel.ScrollUnit="Item"
                                              ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                              SelectionChanged="dgLogsEntries_SelectionChanged">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="Service" Binding="{Binding Service}" Width="160"/>
                                            <DataGridTextColumn Header="Server" Binding="{Binding Server}" Width="120"/>
                                            <DataGridTextColumn Header="Result" Binding="{Binding Result}" Width="74">
                                                <DataGridTextColumn.ElementStyle>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                                        <Setter Property="HorizontalAlignment" Value="Center"/>
                                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                                    </Style>
                                                </DataGridTextColumn.ElementStyle>
                                            </DataGridTextColumn>
                                            <DataGridTextColumn Header="Message" Binding="{Binding Message}" Width="300">
                                                <DataGridTextColumn.ElementStyle>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                                    </Style>
                                                </DataGridTextColumn.ElementStyle>
                                            </DataGridTextColumn>
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </Grid>
                            </Border>

                            <Border Grid.Column="2"
                                Background="#F7FAFD"
                                BorderBrush="{StaticResource PanelBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="12"
                                Padding="0"
                                Margin="8,0,0,0">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>
                                    <Border Background="{StaticResource SoftFillBrush}"
                                            BorderBrush="{StaticResource PanelBorderBrush}"
                                            BorderThickness="0,0,0,1"
                                            CornerRadius="12,12,0,0"
                                            Padding="12,10">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel>
                                                <TextBlock Text="Raw Log Evidence"
                                                           FontSize="14"
                                                           FontWeight="SemiBold"
                                                           Foreground="{StaticResource HeadingBrush}"/>
                                                <TextBlock x:Name="LogsFileNameText"
                                                           Text="No log loaded"
                                                           Margin="0,3,0,0"
                                                           FontSize="12"
                                                           Foreground="{StaticResource BodyBrush}"/>
                                            </StackPanel>
                                            <Button x:Name="PopOutLogViewerButton"
                                                    Grid.Column="1"
                                                    Style="{StaticResource IconButtonStyle}"
                                                    Width="36"
                                                    Height="36"
                                                    Background="#1A73E8"
                                                    FontSize="16"
                                                    VerticalAlignment="Center"
                                                    ToolTip="Open raw log in a separate window"
                                                    Click="PopOutLogViewer_Click">
                                                <TextBlock Text="&#xE8A7;" FontFamily="Segoe MDL2 Assets" FontSize="16"/>
                                            </Button>
                                        </Grid>
                                    </Border>
                                    <ListBox Grid.Row="1"
                                             x:Name="LogsListBox"
                                             Background="Transparent"
                                             BorderThickness="0"
                                             ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                             FontFamily="Consolas"
                                             FontSize="13"
                                             Padding="8">
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding Text}"
                                                           Foreground="{Binding Foreground}"
                                                           FontWeight="{Binding FontWeight}"
                                                           TextWrapping="NoWrap"
                                                           Padding="6,1"/>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                </Grid>
                            </Border>
                        </Grid>
                    </Grid>
                </TabItem>

                <TabItem Header="Security">
                    <Grid Margin="2">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0" Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Background="White" BorderBrush="{StaticResource PanelBorderBrush}" BorderThickness="1" CornerRadius="14" Padding="16" Margin="0,0,6,0">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Text="Total Findings" FontSize="12" Foreground="{StaticResource BodyBrush}" VerticalAlignment="Center"/>
                                    <TextBlock x:Name="SecurityTotalFindingsText" Text="0" FontSize="22" FontWeight="Bold" Foreground="{StaticResource HeadingBrush}" Margin="10,0,0,0"/>
                                </StackPanel>
                            </Border>
                            <Border Grid.Column="1" Background="White" BorderBrush="{StaticResource PanelBorderBrush}" BorderThickness="1" CornerRadius="14" Padding="16" Margin="6,0">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Text="Critical" FontSize="12" Foreground="{StaticResource BodyBrush}" VerticalAlignment="Center"/>
                                    <TextBlock x:Name="SecurityCriticalText" Text="0" FontSize="22" FontWeight="Bold" Foreground="#D32F2F" Margin="10,0,0,0"/>
                                </StackPanel>
                            </Border>
                            <Border Grid.Column="2" Background="White" BorderBrush="{StaticResource PanelBorderBrush}" BorderThickness="1" CornerRadius="14" Padding="16" Margin="6,0">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Text="High" FontSize="12" Foreground="{StaticResource BodyBrush}" VerticalAlignment="Center"/>
                                    <TextBlock x:Name="SecurityHighText" Text="0" FontSize="22" FontWeight="Bold" Foreground="#F57F17" Margin="10,0,0,0"/>
                                </StackPanel>
                            </Border>
                            <Border Grid.Column="3" Background="White" BorderBrush="{StaticResource PanelBorderBrush}" BorderThickness="1" CornerRadius="14" Padding="16" Margin="6,0,0,0">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Text="Privilege Groups" FontSize="12" Foreground="{StaticResource BodyBrush}" VerticalAlignment="Center"/>
                                    <TextBlock x:Name="SecurityPrivGroupCountText" Text="0" FontSize="22" FontWeight="Bold" Foreground="{StaticResource HeadingBrush}" Margin="10,0,0,0"/>
                                </StackPanel>
                            </Border>
                        </Grid>

                        <Border Grid.Row="1"
                                Background="{StaticResource SoftFillBrush}"
                                BorderBrush="{StaticResource PanelBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="14"
                                Padding="14"
                                Margin="0,0,0,10">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Privilege Insights"
                                           FontSize="12"
                                           Foreground="{StaticResource BodyBrush}"
                                           VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="1"
                                           x:Name="PrivilegedInsightsText"
                                           Text="Privilege analysis will appear after a collection runs."
                                           Margin="14,0,0,0"
                                           FontSize="14"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource HeadingBrush}"
                                           TextWrapping="Wrap"
                                           VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="2"
                                           x:Name="SecuritySummaryText"
                                           Text=""
                                           Margin="14,0,0,0"
                                           Foreground="{StaticResource BodyBrush}"
                                           FontSize="12"
                                           TextWrapping="Wrap"
                                           VerticalAlignment="Center"
                                           MaxWidth="400"
                                           TextAlignment="Right"/>
                            </Grid>
                        </Border>

                        <Border Grid.Row="2"
                                Background="White"
                                BorderBrush="{StaticResource PanelBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="12"
                                Padding="0">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <Border Background="{StaticResource SoftFillBrush}"
                                        BorderBrush="{StaticResource PanelBorderBrush}"
                                        BorderThickness="0,0,0,1"
                                        CornerRadius="12,12,0,0"
                                        Padding="12,10">
                                    <TextBlock Text="Security Findings"
                                               FontSize="14"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource HeadingBrush}"/>
                                </Border>
                                <DataGrid Grid.Row="1"
                                          x:Name="dgSecurityFindings"
                                          AutoGenerateColumns="False"
                                          BorderThickness="0"
                                          RowHeaderWidth="0"
                                          RowHeight="40"
                                          HeadersVisibility="Column"
                                          GridLinesVisibility="Horizontal"
                                          SelectionMode="Single"
                                          SelectionUnit="FullRow"
                                          AlternationCount="2"
                                          VirtualizingPanel.VirtualizationMode="Recycling"
                                          VirtualizingPanel.ScrollUnit="Item">
                                    <DataGrid.Resources>
                                        <Style TargetType="DataGridRow" BasedOn="{StaticResource SelectableDataGridRowStyle}">
                                            <Style.Triggers>
                                                <Trigger Property="AlternationIndex" Value="1">
                                                    <Setter Property="Background" Value="#F5F7FA"/>
                                                </Trigger>
                                                <DataTrigger Binding="{Binding Severity}" Value="Critical">
                                                    <Setter Property="Background" Value="#FFEBEE"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Severity}" Value="High">
                                                    <Setter Property="Background" Value="#FFF8E1"/>
                                                </DataTrigger>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter Property="Background" Value="#E3F0FF"/>
                                                    <Setter Property="Foreground" Value="#13293D"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                        <Style TargetType="DataGridCell" BasedOn="{StaticResource SelectableDataGridCellStyle}">
                                            <Setter Property="VerticalAlignment" Value="Center"/>
                                            <Setter Property="Padding" Value="8,0"/>
                                        </Style>
                                    </DataGrid.Resources>
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Severity" Binding="{Binding Severity}" Width="100">
                                            <DataGridTextColumn.ElementStyle>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                                    <Setter Property="Padding" Value="10,0"/>
                                                </Style>
                                            </DataGridTextColumn.ElementStyle>
                                        </DataGridTextColumn>
                                        <DataGridTextColumn Header="Category" Binding="{Binding Category}" Width="130"/>
                                        <DataGridTextColumn Header="Target" Binding="{Binding Target}" Width="200"/>
                                        <DataGridTextColumn Header="Summary" Binding="{Binding Summary}" Width="*"/>
                                        <DataGridTextColumn Header="Evidence" Binding="{Binding Evidence}" Width="*"/>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </Grid>
                        </Border>
                    </Grid>
                </TabItem>
                <TabItem Header="Settings">
                    <Grid Margin="2">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Grid Margin="0,0,0,14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Settings"
                                       FontSize="22"
                                       FontWeight="Bold"
                                       Foreground="{StaticResource HeadingBrush}"/>
                            <Button Grid.Column="1"
                                    Content="Save Settings"
                                    Style="{StaticResource RoundedButtonStyle}"
                                    Background="{StaticResource SidebarActiveBrush}"
                                    Width="140"
                                    Height="38"
                                    Click="SettingsSaveButton_Click"/>
                        </Grid>
                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                            <StackPanel>
                                <Border Background="White"
                                        BorderBrush="{StaticResource PanelBorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="12"
                                        Padding="18"
                                        Margin="0,0,0,14">
                                    <StackPanel>
                                        <TextBlock Text="Domain Controllers"
                                                   FontSize="16"
                                                   FontWeight="SemiBold"
                                                   Foreground="{StaticResource HeadingBrush}"
                                                   Margin="0,0,0,4"/>
                                        <TextBlock Text="Comma-separated list of DC hostnames or IPs."
                                                   Foreground="{StaticResource BodyBrush}"
                                                   FontSize="13"
                                                   Margin="0,0,0,10"/>
                                        <TextBox x:Name="SettingsDcTextBox"
                                                 FontSize="14"
                                                 Padding="10,8"
                                                 BorderBrush="#C7D5E2"
                                                 BorderThickness="1"
                                                 Background="White"/>
                                    </StackPanel>
                                </Border>

                                 <Border Background="White"
                                         BorderBrush="{StaticResource PanelBorderBrush}"
                                         BorderThickness="1"
                                         CornerRadius="12"
                                         Padding="18"
                                         Margin="0,0,0,14">
                                     <StackPanel>
                                         <TextBlock Text="Email Notifications"
                                                    FontSize="16"
                                                    FontWeight="SemiBold"
                                                    Foreground="{StaticResource HeadingBrush}"
                                                    Margin="0,0,0,4"/>
                                         <TextBlock Text="Recipient address for test result emails."
                                                    Foreground="{StaticResource BodyBrush}"
                                                    FontSize="13"
                                                    Margin="0,0,0,10"/>
                                         <TextBox x:Name="SettingsEmailTextBox"
                                                  FontSize="14"
                                                  Padding="10,8"
                                                  BorderBrush="#C7D5E2"
                                                  BorderThickness="1"
                                                  Background="White"/>
                                          <CheckBox x:Name="SettingsChkEmailManual"
                                                    Style="{StaticResource SettingsCheckBoxStyle}"
                                                    Content="Send email on manual runs"
                                                    Margin="0,10,0,6"
                                                    IsChecked="True"/>
                                          <CheckBox x:Name="SettingsChkEmailScheduled"
                                                    Style="{StaticResource SettingsCheckBoxStyle}"
                                                    Content="Send email on scheduled runs"
                                                    Margin="0,0,0,4"
                                                    IsChecked="True"/>
                                     </StackPanel>
                                 </Border>

                                 <Border Background="White"
                                         BorderBrush="{StaticResource PanelBorderBrush}"
                                         BorderThickness="1"
                                         CornerRadius="12"
                                         Padding="18"
                                         Margin="0,0,0,14">
                                     <StackPanel>
                                         <TextBlock Text="Optional Tests"
                                                   FontSize="16"
                                                   FontWeight="SemiBold"
                                                   Foreground="{StaticResource HeadingBrush}"
                                                   Margin="0,0,0,4"/>
                                        <TextBlock Text="Toggle which additional checks run with each test."
                                                   Foreground="{StaticResource BodyBrush}"
                                                   FontSize="13"
                                                   Margin="0,0,0,12"/>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel>
                                                <CheckBox x:Name="SettingsChkDns" Style="{StaticResource SettingsCheckBoxStyle}" Content="DNS Resolution" Margin="0,0,0,6" IsChecked="True"/>
                                                <CheckBox x:Name="SettingsChkReplication" Style="{StaticResource SettingsCheckBoxStyle}" Content="Replication (repadmin)" Margin="0,0,0,6" IsChecked="True"/>
                                                <CheckBox x:Name="SettingsChkTimeSkew" Style="{StaticResource SettingsCheckBoxStyle}" Content="Time Skew (w32tm)" Margin="0,0,0,6" IsChecked="True"/>
                                            </StackPanel>
                                            <StackPanel Grid.Column="1">
                                                <CheckBox x:Name="SettingsChkLdapBind" Style="{StaticResource SettingsCheckBoxStyle}" Content="LDAP Bind" Margin="0,0,0,6" IsChecked="True"/>
                                                <CheckBox x:Name="SettingsChkCertDhcp" Style="{StaticResource SettingsCheckBoxStyle}" Content="Cert Services &amp; DHCP" Margin="0,0,0,6" IsChecked="True"/>
                                                <CheckBox x:Name="SettingsChkSmbSigning" Style="{StaticResource SettingsCheckBoxStyle}" Content="SMB/LDAP Signing" Margin="0,0,0,6" IsChecked="True"/>
                                            </StackPanel>
                                        </Grid>
                                    </StackPanel>
                                </Border>

                                <Border Background="White"
                                        BorderBrush="{StaticResource PanelBorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="12"
                                        Padding="18"
                                        Margin="0,0,0,14">
                                    <StackPanel>
                                        <TextBlock Text="Email Test"
                                                   FontSize="16"
                                                   FontWeight="SemiBold"
                                                   Foreground="{StaticResource HeadingBrush}"
                                                   Margin="0,0,0,4"/>
                                        <TextBlock Text="Send a test email to verify SMTP configuration."
                                                   Foreground="{StaticResource BodyBrush}"
                                                   FontSize="13"
                                                   Margin="0,0,0,10"/>
                                         <Button x:Name="SettingsTestEmailButton"
                                                 Content="Send Test Email"
                                                 Style="{StaticResource RoundedButtonStyle}"
                                                 Background="#2E7D32"
                                                 Width="140"
                                                 Height="36"
                                                 HorizontalAlignment="Left"
                                                 Click="TestEmailButton_Click"/>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </ScrollViewer>
                    </Grid>
                </TabItem>
                <TabItem Header="Scheduler">
                    <Grid Margin="2">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Grid Grid.Row="1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1.5*"/>
                                <ColumnDefinition Width="1*"/>
                            </Grid.ColumnDefinitions>
                            <Border Background="#F8FAFC"
                                    BorderBrush="{StaticResource PanelBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="12"
                                    Padding="14"
                                    Margin="0,0,14,0">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="Scheduled Tasks"
                                                   FontSize="16"
                                                   FontWeight="SemiBold"
                                                   Foreground="{StaticResource HeadingBrush}"/>
                                        <TextBlock Text="Select a task to edit or remove."
                                                   FontSize="12"
                                                   Foreground="{StaticResource BodyBrush}"
                                                   Margin="0,2,0,10"/>
                                    </StackPanel>
                                    <DataGrid Grid.Row="1"
                                               x:Name="SchedulerTaskList"
                                               AutoGenerateColumns="False"
                                               BorderThickness="0"
                                               AlternationCount="2"
                                               VirtualizingPanel.VirtualizationMode="Recycling"
                                               VirtualizingPanel.ScrollUnit="Item"
                                               RowHeaderWidth="0"
                                               RowHeight="40"
                                               HeadersVisibility="Column"
                                               GridLinesVisibility="Horizontal"
                                               SelectionMode="Extended"
                                               SelectionUnit="FullRow"
                                               PreviewMouseLeftButtonDown="DataGrid_CellPreviewMouseLeftButtonDown"
                                               SelectionChanged="SchedulerTaskList_SelectionChanged"
                                               CanUserAddRows="False"
                                               IsReadOnly="True">
                                         <DataGrid.Resources>
                                             <Style TargetType="TextBlock">
                                                 <Setter Property="VerticalAlignment" Value="Center"/>
                                                 <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                                             </Style>
                                             <Style TargetType="CheckBox">
                                                 <Setter Property="VerticalAlignment" Value="Center"/>
                                             </Style>
                                         </DataGrid.Resources>
                                         <DataGrid.CellStyle>
                                             <Style TargetType="DataGridCell">
                                                 <Setter Property="VerticalContentAlignment" Value="Center"/>
                                                 <Setter Property="Padding" Value="10,0"/>
                                                 <Setter Property="BorderThickness" Value="0"/>
                                                 <Setter Property="Background" Value="Transparent"/>
                                                 <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                                             </Style>
                                         </DataGrid.CellStyle>
                                         <DataGrid.Columns>
                                             <DataGridTemplateColumn Width="36">
                                                 <DataGridTemplateColumn.Header>
                                                     <CheckBox Style="{StaticResource HeaderCheckBoxStyle}"
                                                               HorizontalAlignment="Center"
                                                               VerticalAlignment="Center"
                                                               Checked="SelectAllCheckBox_Checked"
                                                               Unchecked="SelectAllCheckBox_Unchecked"/>
                                                 </DataGridTemplateColumn.Header>
                                                 <DataGridTemplateColumn.CellTemplate>
                                                     <DataTemplate>
                                                         <Grid VerticalAlignment="Center">
                                                             <CheckBox Style="{StaticResource RowCheckBoxStyle}"
                                                                       HorizontalAlignment="Center"
                                                                       VerticalAlignment="Center"
                                                                       Focusable="False"
                                                                       IsChecked="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type DataGridRow}}, Path=IsSelected, Mode=OneWay}"
                                                                       PreviewMouseLeftButtonDown="RowCheckBox_PreviewMouseLeftButtonDown"
                                                                       Checked="RowCheckBox_Checked"
                                                                       Unchecked="RowCheckBox_Unchecked"/>
                                                         </Grid>
                                                      </DataTemplate>
                                                  </DataGridTemplateColumn.CellTemplate>
                                              </DataGridTemplateColumn>
                                             <DataGridTemplateColumn Header="Task Name" Width="*">
                                                 <DataGridTemplateColumn.CellTemplate>
                                                     <DataTemplate>
                                                         <TextBlock Text="{Binding TaskName}"
                                                                    VerticalAlignment="Center"
                                                                    Margin="0,1,0,0"
                                                                    TextTrimming="CharacterEllipsis"/>
                                                     </DataTemplate>
                                                 </DataGridTemplateColumn.CellTemplate>
                                             </DataGridTemplateColumn>
                                            <DataGridTemplateColumn Header="DC" Width="1.2*">
                                                <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <TextBlock Text="{Binding DomainController}"
                                                                   VerticalAlignment="Center"
                                                                   Margin="0,1,0,0"
                                                                   TextTrimming="CharacterEllipsis"/>
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>
                                            </DataGridTemplateColumn>
                                            <DataGridTemplateColumn Header="Frequency" Width="90">
                                                <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <TextBlock Text="{Binding Frequency}"
                                                                   VerticalAlignment="Center"
                                                                   Margin="0,1,0,0"
                                                                   TextTrimming="CharacterEllipsis"/>
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>
                                            </DataGridTemplateColumn>
                                            <DataGridTemplateColumn Header="Date" Width="80">
                                                <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <TextBlock Text="{Binding StartDate, StringFormat={}{0:dd MMM}}"
                                                                   VerticalAlignment="Center"
                                                                   Margin="0,1,0,0"
                                                                   TextTrimming="CharacterEllipsis"/>
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>
                                            </DataGridTemplateColumn>
                                            <DataGridTemplateColumn Header="Time" Width="65">
                                                <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <TextBlock Text="{Binding StartTime}"
                                                                   VerticalAlignment="Center"
                                                                   Margin="0,1,0,0"
                                                                   TextTrimming="CharacterEllipsis"/>
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>
                                            </DataGridTemplateColumn>
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </Grid>
                            </Border>

                            <StackPanel Grid.Column="1">
                                <Border Background="White"
                                        BorderBrush="{StaticResource PanelBorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="12"
                                        Padding="18">
                                    <StackPanel>
                                        <TextBlock Text="Create or Edit Task"
                                                   FontSize="16"
                                                   FontWeight="SemiBold"
                                                   Foreground="{StaticResource HeadingBrush}"
                                                   Margin="0,0,0,4"/>
                                        <TextBlock Text="Set up recurring AD health checks."
                                                   Foreground="{StaticResource BodyBrush}"
                                                   FontSize="13"
                                                   Margin="0,0,0,12"/>

                                        <TextBlock Text="Task Name" FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource HeadingBrush}"/>
                                        <TextBox x:Name="SchedulerTaskName"
                                                 FontSize="14"
                                                 Padding="8"
                                                 Height="38"
                                                 BorderBrush="#C7D5E2"
                                                 BorderThickness="1"
                                                 Background="White"
                                                 Margin="0,4,0,10"/>

                                        <TextBlock Text="Domain Controllers" FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource HeadingBrush}"/>
                                        <TextBox x:Name="SchedulerDomainControllers"
                                                 FontSize="14"
                                                 Padding="8"
                                                 Height="60"
                                                 BorderBrush="#C7D5E2"
                                                 BorderThickness="1"
                                                 Background="White"
                                                 Margin="0,4,0,10"
                                                 AcceptsReturn="True"
                                                 TextWrapping="Wrap"
                                                 VerticalScrollBarVisibility="Auto"/>

                                        <TextBlock Text="Frequency" FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource HeadingBrush}"/>
                                        <ComboBox x:Name="SchedulerFrequency"
                                                  FontSize="14"
                                                  Padding="5"
                                                  Height="38"
                                                  BorderBrush="#C7D5E2"
                                                  BorderThickness="1"
                                                  Background="White"
                                                  Margin="0,4,0,10"
                                                  SelectedIndex="0">
                                            <ComboBoxItem Content="Daily"/>
                                            <ComboBoxItem Content="Weekly"/>
                                            <ComboBoxItem Content="Monthly"/>
                                            <ComboBoxItem Content="Hourly"/>
                                        </ComboBox>

                                        <Grid Margin="0,0,0,10">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" Margin="0,0,6,0">
                                                <TextBlock Text="Start Date" FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource HeadingBrush}"/>
                                                <DatePicker x:Name="SchedulerStartDate"
                                                            FontSize="14"
                                                            Padding="5"
                                                            Height="38"
                                                            BorderBrush="#C7D5E2"
                                                            BorderThickness="1"
                                                            Background="White"
                                                            Margin="0,4,0,0"/>
                                            </StackPanel>
                                            <StackPanel Grid.Column="1" Margin="6,0,0,0">
                                                <TextBlock Text="Start Time (HH:mm)" FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource HeadingBrush}"/>
                                                <TextBox x:Name="SchedulerStartTime"
                                                         FontSize="14"
                                                         Padding="8"
                                                         Height="38"
                                                         BorderBrush="#C7D5E2"
                                                         BorderThickness="1"
                                                         Background="White"
                                                         Margin="0,4,0,0"/>
                                            </StackPanel>
                                        </Grid>

                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,6,0,0">
                                            <Button Content="Save"
                                                    Style="{StaticResource RoundedButtonStyle}"
                                                    Background="{StaticResource SidebarActiveBrush}"
                                                    Width="80"
                                                    Margin="0,0,10,0"
                                                    Click="SchedulerSaveButton_Click"/>
                                            <Button Content="Remove"
                                                    Style="{StaticResource RoundedButtonStyle}"
                                                    Background="#D32F2F"
                                                    Width="90"
                                                    Click="SchedulerRemoveButton_Click"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Grid>
                    </Grid>
                </TabItem>
            </TabControl>
        </Border>
        </Grid>
    </Grid>
</Window>
