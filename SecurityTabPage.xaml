<UserControl x:Class="AdHealthMonitor.SecurityTabPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
                    <Grid Margin="2">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0" Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Background="White" BorderBrush="{StaticResource PanelBorderBrush}" BorderThickness="1" CornerRadius="14" Padding="16" Margin="0,0,6,0">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Text="Total Findings" FontSize="12" Foreground="{StaticResource BodyBrush}" VerticalAlignment="Center"/>
                                    <TextBlock x:Name="SecurityTotalFindingsText" x:FieldModifier="public" Text="0" FontSize="22" FontWeight="Bold" Foreground="{StaticResource HeadingBrush}" Margin="10,0,0,0"/>
                                </StackPanel>
                            </Border>
                            <Border Grid.Column="1" Background="White" BorderBrush="{StaticResource PanelBorderBrush}" BorderThickness="1" CornerRadius="14" Padding="16" Margin="6,0">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Text="Critical" FontSize="12" Foreground="{StaticResource BodyBrush}" VerticalAlignment="Center"/>
                                    <TextBlock x:Name="SecurityCriticalText" x:FieldModifier="public" Text="0" FontSize="22" FontWeight="Bold" Foreground="#D32F2F" Margin="10,0,0,0"/>
                                </StackPanel>
                            </Border>
                            <Border Grid.Column="2" Background="White" BorderBrush="{StaticResource PanelBorderBrush}" BorderThickness="1" CornerRadius="14" Padding="16" Margin="6,0">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Text="High" FontSize="12" Foreground="{StaticResource BodyBrush}" VerticalAlignment="Center"/>
                                    <TextBlock x:Name="SecurityHighText" x:FieldModifier="public" Text="0" FontSize="22" FontWeight="Bold" Foreground="#F57F17" Margin="10,0,0,0"/>
                                </StackPanel>
                            </Border>
                            <Border Grid.Column="3" Background="White" BorderBrush="{StaticResource PanelBorderBrush}" BorderThickness="1" CornerRadius="14" Padding="16" Margin="6,0,0,0">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Text="Admin Accounts" FontSize="12" Foreground="{StaticResource BodyBrush}" VerticalAlignment="Center"/>
                                    <TextBlock x:Name="SecurityPrivGroupCountText" x:FieldModifier="public" Text="0" FontSize="22" FontWeight="Bold" Foreground="{StaticResource HeadingBrush}" Margin="10,0,0,0"/>
                                </StackPanel>
                            </Border>
                        </Grid>

                        <Border Grid.Row="1"
                                Background="{StaticResource SoftFillBrush}"
                                BorderBrush="{StaticResource PanelBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="14"
                                Padding="14"
                                Margin="0,0,0,6">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Privilege Insights"
                                           FontSize="12"
                                           Foreground="{StaticResource BodyBrush}"
                                           VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="1"
                                           x:Name="PrivilegedInsightsText" x:FieldModifier="public"
                                           Text="Privilege analysis will appear after a collection runs."
                                           Margin="14,0,0,0"
                                           FontSize="14"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource HeadingBrush}"
                                           TextWrapping="Wrap"
                                           VerticalAlignment="Center"/>
                            </Grid>
                        </Border>

                        <Border Grid.Row="2"
                                Background="{StaticResource SoftFillBrush}"
                                BorderBrush="{StaticResource PanelBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="14"
                                Padding="14"
                                Margin="0,0,0,10">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Security Summary"
                                           FontSize="12"
                                           Foreground="{StaticResource BodyBrush}"
                                           VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="1"
                                           x:Name="SecuritySummaryText" x:FieldModifier="public"
                                           Text=""
                                           Margin="14,0,0,0"
                                           Foreground="{StaticResource BodyBrush}"
                                           FontSize="12"
                                           TextWrapping="Wrap"
                                           TextAlignment="Left"
                                           VerticalAlignment="Center"/>
                            </Grid>
                        </Border>

                        <Border Grid.Row="3"
                                Background="White"
                                BorderBrush="{StaticResource PanelBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="12"
                                Padding="0">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <Border Background="{StaticResource SoftFillBrush}"
                                        BorderBrush="{StaticResource PanelBorderBrush}"
                                        BorderThickness="0,0,0,1"
                                        CornerRadius="12,12,0,0"
                                        Padding="12,10">
                                    <TextBlock Text="Security Findings"
                                               FontSize="14"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource HeadingBrush}"/>
                                </Border>
                                <DataGrid Grid.Row="1"
                                          x:Name="dgSecurityFindings" x:FieldModifier="public"
                                          AutoGenerateColumns="False"
                                          IsReadOnly="True"
                                          BorderThickness="0"
                                          RowHeaderWidth="0"
                                          RowHeight="40"
                                          HeadersVisibility="Column"
                                          GridLinesVisibility="Horizontal"
                                          SelectionMode="Single"
                                          SelectionUnit="FullRow"
                                          AlternationCount="2"
                                          VirtualizingPanel.VirtualizationMode="Recycling"
                                          VirtualizingPanel.ScrollUnit="Item">
                                    <DataGrid.Resources>
                                        <Style TargetType="DataGridRow" BasedOn="{StaticResource SelectableDataGridRowStyle}">
                                            <Style.Triggers>
                                                <Trigger Property="AlternationIndex" Value="1">
                                                    <Setter Property="Background" Value="#F5F7FA"/>
                                                </Trigger>
                                                <DataTrigger Binding="{Binding Severity}" Value="Critical">
                                                    <Setter Property="Background" Value="#FFEBEE"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Severity}" Value="High">
                                                    <Setter Property="Background" Value="#FFF8E1"/>
                                                </DataTrigger>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter Property="Background" Value="#E3F0FF"/>
                                                    <Setter Property="Foreground" Value="#13293D"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                        <Style TargetType="DataGridCell" BasedOn="{StaticResource SelectableDataGridCellStyle}">
                                            <Setter Property="VerticalAlignment" Value="Center"/>
                                            <Setter Property="Padding" Value="8,0"/>
                                        </Style>
                                    </DataGrid.Resources>
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Severity" Binding="{Binding Severity}" Width="100">
                                            <DataGridTextColumn.ElementStyle>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                                    <Setter Property="Padding" Value="10,0"/>
                                                </Style>
                                            </DataGridTextColumn.ElementStyle>
                                        </DataGridTextColumn>
                                        <DataGridTextColumn Header="Category" Binding="{Binding Category}" Width="130"/>
                                        <DataGridTextColumn Header="Target" Binding="{Binding Target}" Width="200"/>
                                        <DataGridTextColumn Header="Summary" Binding="{Binding Summary}" Width="*"/>
                                        <DataGridTextColumn Header="Evidence" Binding="{Binding Evidence}" Width="*"/>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </Grid>
                        </Border>
                    </Grid>
</UserControl>
