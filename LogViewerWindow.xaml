<Window x:Class="AdHealthMonitor.LogViewerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Raw Log Evidence"
        Height="700"
        Width="1000"
        MinWidth="400"
        MinHeight="300"
        WindowStartupLocation="CenterOwner"
        Background="#EEF3F8"
        FontFamily="Segoe UI"
        ShowInTaskbar="True"
        WindowStyle="None"
        ResizeMode="CanResizeWithGrip"
        AllowsTransparency="True"
        Loaded="Window_Loaded">
    <Window.Resources>
        <Style TargetType="ScrollBar">
            <Setter Property="Width" Value="4"/>
            <Setter Property="Height" Value="4"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid Background="{TemplateBinding Background}">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="0"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="0"/>
                            </Grid.RowDefinitions>
                            <RepeatButton x:Name="PART_DecreaseRepeatButton" Height="0" Focusable="False"/>
                            <Track x:Name="PART_Track" Grid.Row="1" IsDirectionReversed="true">
                                <Track.Resources>
                                    <Style TargetType="RepeatButton">
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Setter Property="BorderThickness" Value="0"/>
                                        <Setter Property="Focusable" Value="False"/>
                                    </Style>
                                </Track.Resources>
                                <Track.Thumb>
                                    <Thumb BorderThickness="0" Focusable="False">
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Border Background="#C1C9D2" CornerRadius="3" Margin="1,0" Opacity="0.6"/>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                            <RepeatButton x:Name="PART_IncreaseRepeatButton" Grid.Row="2" Height="0" Focusable="False"/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="Orientation" Value="Horizontal">
                    <Setter Property="Height" Value="4"/>
                    <Setter Property="Width" Value="Auto"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ScrollBar">
                                <Grid Background="{TemplateBinding Background}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="0"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="0"/>
                                    </Grid.ColumnDefinitions>
                                    <RepeatButton x:Name="PART_DecreaseRepeatButton" Width="0" Focusable="False"/>
                                    <Track x:Name="PART_Track" Grid.Column="1" IsDirectionReversed="False">
                                        <Track.Resources>
                                            <Style TargetType="RepeatButton">
                                                <Setter Property="Background" Value="Transparent"/>
                                                <Setter Property="BorderThickness" Value="0"/>
                                                <Setter Property="Focusable" Value="False"/>
                                            </Style>
                                        </Track.Resources>
                                        <Track.Thumb>
                                            <Thumb BorderThickness="0" Focusable="False">
                                                <Thumb.Template>
                                                    <ControlTemplate TargetType="Thumb">
                                                        <Border Background="#C1C9D2" CornerRadius="3" Margin="0,1" Opacity="0.6"/>
                                                    </ControlTemplate>
                                                </Thumb.Template>
                                            </Thumb>
                                        </Track.Thumb>
                                    </Track>
                                    <RepeatButton x:Name="PART_IncreaseRepeatButton" Grid.Column="2" Width="0" Focusable="False"/>
                                </Grid>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>
    <Border Background="#EEF3F8" BorderThickness="0">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="40"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Background="#17324D"
                    CornerRadius="12,12,0,0"
                    Padding="16,0"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="&#xE8A7;"
                               FontFamily="Segoe MDL2 Assets"
                               FontSize="16"
                               Foreground="White"
                               VerticalAlignment="Center"/>
                    <TextBlock x:Name="TitleText"
                               Grid.Column="1"
                               Text="Raw Log Evidence"
                               FontSize="14"
                               FontWeight="SemiBold"
                               Foreground="White"
                               VerticalAlignment="Center"
                               Margin="10,0,0,0"/>
                    <StackPanel Grid.Column="2" Orientation="Horizontal">
                        <Button x:Name="RefreshLogButton"
                                Content="&#xE72C;"
                                FontFamily="Segoe MDL2 Assets"
                                FontSize="14"
                                Width="32"
                                Height="32"
                                Background="Transparent"
                                Foreground="White"
                                BorderThickness="0"
                                Margin="0,0,4,0"
                                ToolTip="Refresh from main window"
                                Click="RefreshLogButton_Click"/>
                        <Button x:Name="CloseButton"
                                Content="&#xE8BB;"
                                FontFamily="Segoe MDL2 Assets"
                                FontSize="14"
                                Width="32"
                                Height="32"
                                Background="Transparent"
                                Foreground="White"
                                BorderThickness="0"
                                Click="CloseButton_Click"/>
                    </StackPanel>
                </Grid>
            </Border>

            <TextBox x:Name="LogContentBox"
                     Grid.Row="1"
                     IsReadOnly="True"
                     FontFamily="Consolas"
                     FontSize="13"
                     TextWrapping="NoWrap"
                     HorizontalScrollBarVisibility="Auto"
                     VerticalScrollBarVisibility="Auto"
                     AcceptsReturn="True"
                     BorderThickness="0"
                     Background="White"
                     Padding="12,8"
                     Margin="0,0,0,0"/>

            <Border Grid.Row="2"
                    Background="#E8EDF2"
                    CornerRadius="0,0,12,12"
                    Padding="12,6">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock x:Name="StatsText"
                               Text=""
                               FontSize="12"
                               Foreground="#5D6F82"
                               VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="2"
                               Text="&#xE737; Drag to resize"
                               FontFamily="Segoe MDL2 Assets"
                               FontSize="11"
                               Foreground="#8A97A6"
                               VerticalAlignment="Center"/>
                </Grid>
            </Border>

            <GridSplitter Grid.Row="0"
                          Grid.RowSpan="3"
                          HorizontalAlignment="Right"
                          VerticalAlignment="Bottom"
                          Width="12"
                          Height="12"
                          Background="Transparent"
                          ResizeDirection="Auto"
                          ResizeBehavior="CurrentAndNext"/>
        </Grid>
    </Border>
</Window>
