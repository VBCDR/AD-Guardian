<UserControl x:Class="AdHealthMonitor.HealthTabPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
                    <Grid Margin="2">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0"
                                Background="White"
                                BorderBrush="{StaticResource PanelBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="14"
                                Padding="12"
                                Margin="0,0,0,10">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Orientation="Horizontal">
                                    <Button x:Name="RunButton" x:FieldModifier="public"
                                            Style="{StaticResource RoundedButtonStyleStart}"
                                            Width="130"
                                            Height="40"
                                            Click="RunButton_Click">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="&#xE768;" FontFamily="Segoe MDL2 Assets" FontSize="12" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                            <TextBlock Text="Run Tests" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Button>
                                     <Button x:Name="StopButton" x:FieldModifier="public"
                                             Style="{StaticResource RoundedButtonStyleStop}"
                                             Width="130"
                                             Height="40"
                                             Margin="8,0,0,0"
                                             IsEnabled="False"
                                             Click="StopButton_Click">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="&#xE71A;" FontFamily="Segoe MDL2 Assets" FontSize="14" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                            <TextBlock Text="Stop" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Button>
                                    <Button x:Name="ExportButton" x:FieldModifier="public"
                                            Content="Export"
                                            Style="{StaticResource RoundedButtonStyle}"
                                            Background="#1A73E8"
                                            Width="106"
                                            Height="40"
                                            Margin="8,0,0,0"
                                            Click="ExportButton_Click"/>
                                    <Button x:Name="ExecutiveSummaryButton" x:FieldModifier="public"
                                            Content="Summary"
                                            Style="{StaticResource RoundedButtonStyle}"
                                            Background="#1A73E8"
                                            Width="110"
                                            Height="40"
                                            Margin="8,0,0,0"
                                            Click="ExecutiveSummary_Click"/>
                                        </StackPanel>
                                    </Grid>
                                    </Border>

                        <Grid Grid.Row="1" Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Background="White" BorderBrush="{StaticResource PanelBorderBrush}" BorderThickness="1" CornerRadius="14" Padding="16" Margin="0,0,6,0">
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="Health Score" FontSize="16" FontWeight="SemiBold" Foreground="{StaticResource HeadingBrush}"/>
                                    <TextBlock x:Name="HealthScoreText" x:FieldModifier="public" Text="100" FontSize="22" FontWeight="Bold" Foreground="{StaticResource HeadingBrush}" Margin="0,4,0,0"/>
                                </StackPanel>
                            </Border>
                            <Border Grid.Column="1" Background="White" BorderBrush="{StaticResource PanelBorderBrush}" BorderThickness="1" CornerRadius="14" Padding="16" Margin="6,0">
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="Critical Findings" FontSize="16" FontWeight="SemiBold" Foreground="{StaticResource HeadingBrush}"/>
                                    <TextBlock x:Name="CriticalFindingsText" x:FieldModifier="public" Text="0" FontSize="22" FontWeight="Bold" Foreground="#D32F2F" Margin="0,4,0,0"/>
                                </StackPanel>
                            </Border>
                            <Border Grid.Column="2" Background="White" BorderBrush="{StaticResource PanelBorderBrush}" BorderThickness="1" CornerRadius="14" Padding="16" Margin="6,0">
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="Passing Tests" FontSize="16" FontWeight="SemiBold" Foreground="{StaticResource HeadingBrush}"/>
                                    <TextBlock x:Name="PassingTestsText" x:FieldModifier="public" Text="0" FontSize="22" FontWeight="Bold" Foreground="#2E7D32" Margin="0,4,0,0"/>
                                </StackPanel>
                            </Border>
                            <Border Grid.Column="3" Background="White" BorderBrush="{StaticResource PanelBorderBrush}" BorderThickness="1" CornerRadius="14" Padding="16" Margin="6,0,0,0">
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="Configured DCs" FontSize="16" FontWeight="SemiBold" Foreground="{StaticResource HeadingBrush}"/>
                                    <TextBlock x:Name="DomainControllerCountText" x:FieldModifier="public" Text="0" FontSize="22" FontWeight="Bold" Foreground="{StaticResource HeadingBrush}" Margin="0,4,0,0"/>
                                </StackPanel>
                            </Border>
                        </Grid>

                        <Border Grid.Row="2"
                                Background="{StaticResource SoftFillBrush}"
                                BorderBrush="{StaticResource PanelBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="12"
                                Padding="12"
                                Margin="0,0,0,10">
                            <TextBlock x:Name="HealthSummaryText" x:FieldModifier="public"
                                       Text="No run data loaded yet."
                                       Foreground="{StaticResource BodyBrush}"
                                       TextWrapping="Wrap"/>
                        </Border>

                        <Border x:Name="DetailsPanel" x:FieldModifier="public"
                                Grid.Row="3"
                                Background="#F7FAFD"
                                BorderBrush="#D7E2EC"
                                BorderThickness="1"
                                CornerRadius="10"
                                Padding="10"
                                Margin="0,0,0,10"
                                Visibility="Collapsed">
                            <TextBox x:Name="ResultsTextBox" x:FieldModifier="public"
                                     AcceptsReturn="True"
                                     IsReadOnly="True"
                                     Style="{StaticResource ModernTextBoxStyle}"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     Padding="6"
                                     MaxHeight="80"
                                     VerticalScrollBarVisibility="Auto"
                                     TextWrapping="Wrap"/>
                        </Border>

                        <Grid Grid.Row="4" Margin="0,0,0,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <Border Grid.Row="0"
                                    Background="White"
                                    BorderBrush="{StaticResource PanelBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="12"
                                    Padding="0"
                                    Margin="0,0,0,10">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>
                                    <Border Background="{StaticResource SoftFillBrush}"
                                            BorderBrush="{StaticResource PanelBorderBrush}"
                                            BorderThickness="0,0,0,1"
                                            CornerRadius="12,12,0,0"
                                            Padding="12,10">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                <TextBlock Text="Results"
                                                           FontSize="14"
                                                           FontWeight="SemiBold"
                                                           Foreground="{StaticResource HeadingBrush}"
                                                           VerticalAlignment="Center"/>
                                                <Border Background="{StaticResource SoftFillBrush}"
                                                        CornerRadius="8"
                                                        Padding="4"
                                                        Margin="12,0,0,0">
                                                    <StackPanel Orientation="Horizontal">
                                                        <Grid>
                                                            <TextBox x:Name="SearchBox" x:FieldModifier="public"
                                                                     Width="200"
                                                                     Height="30"
                                                                     Style="{StaticResource ModernTextBoxStyle}"
                                                                     TextChanged="SearchBox_TextChanged"
                                                                     GotFocus="SearchBox_GotFocus"
                                                                     LostFocus="SearchBox_LostFocus"
                                                                     VerticalAlignment="Center"/>
                                                            <TextBlock x:Name="SearchPlaceholder" x:FieldModifier="public"
                                                                       Text="Search results..."
                                                                       FontSize="13"
                                                                       Foreground="#8A97A6"
                                                                       Margin="8,5,0,0"
                                                                       IsHitTestVisible="False"
                                                                       HorizontalAlignment="Left"/>
                                                        </Grid>
                                                        <Button x:Name="SearchButton" x:FieldModifier="public"
                                                                Content="&#xE721;"
                                                                Style="{StaticResource IconButtonStyle}"
                                                                Background="#1A73E8"
                                                                Width="30"
                                                                Height="30"
                                                                FontSize="14"
                                                                Click="SearchButton_Click"
                                                                Margin="2,0,0,0"
                                                                VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Border>
                                            </StackPanel>
                                            <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                                                <Button x:Name="ViewSelectedLogButton" x:FieldModifier="public"
                                                        Content="View Log"
                                                        Style="{StaticResource RoundedButtonStyle}"
                                                        Background="#1A73E8"
                                                        Width="130"
                                                        Height="36"
                                                        Padding="14,6"
                                                        Margin="0,0,6,0"
                                                        Click="ViewSelectedLog_Click"/>
                                                <Button Content="Clear"
                                                        Style="{StaticResource RoundedButtonStyle}"
                                                        Background="#D9D9D9"
                                                        Foreground="#203244"
                                                        Width="100"
                                                        Height="36"
                                                        Padding="14,6"
                                                        Margin="0,0,4,0"
                                                        Click="ClearResults_Click"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                      <DataGrid x:Name="testResultsGrid" x:FieldModifier="public"
                                              Grid.Row="1"
                                              AutoGenerateColumns="False"
                                              HeadersVisibility="Column"
                                              BorderThickness="0"
                                              SelectionMode="Extended"
                                              SelectionUnit="FullRow"
                                              SelectionChanged="DataGrid_SelectionChanged"
                                              PreviewMouseLeftButtonDown="DataGrid_CellPreviewMouseLeftButtonDown"
                                              VirtualizingPanel.VirtualizationMode="Recycling"
                                              VirtualizingPanel.ScrollUnit="Item">
                                        <DataGrid.Columns>
                                             <DataGridTemplateColumn Width="39.5">
                                                <DataGridTemplateColumn.Header>
                                                    <CheckBox Style="{StaticResource HeaderCheckBoxStyle}"
                                                              HorizontalAlignment="Center"
                                                              VerticalAlignment="Center"
                                                              Checked="SelectAllCheckBox_Checked"
                                                              Unchecked="SelectAllCheckBox_Unchecked"/>
                                                </DataGridTemplateColumn.Header>
                                                <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <CheckBox Style="{StaticResource RowCheckBoxStyle}"
                                                                  HorizontalAlignment="Center"
                                                                  VerticalAlignment="Center"
                                                                  IsChecked="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type DataGridRow}}, Path=IsSelected, Mode=OneWay}"
                                                                    PreviewMouseLeftButtonDown="RowCheckBox_PreviewMouseLeftButtonDown"
                                                                    Checked="RowCheckBox_Checked"
                                                                    Unchecked="RowCheckBox_Unchecked"/>
                                                     </DataTemplate>
                                                 </DataGridTemplateColumn.CellTemplate>
                                             </DataGridTemplateColumn>
                                             <DataGridTextColumn Header="Services" Binding="{Binding Service}" Width="2*" />
                                            <DataGridTextColumn Header="Server" Binding="{Binding Server}" Width="2*" />
                                            <DataGridTextColumn Header="Result" Binding="{Binding Result}" CellStyle="{StaticResource ResultCellStyle}" Width="Auto"/>
                                             <DataGridTextColumn Header="Message" Binding="{Binding Message}" Width="3*" />
                                         </DataGrid.Columns>
                                    </DataGrid>
                                </Grid>
                            </Border>
                        </Grid>
                    </Grid>
</UserControl>
