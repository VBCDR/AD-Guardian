<Window x:Class="Domain_Guardian.UpdatePromptWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Update Available"
        Width="480"
        MinWidth="480"
        MaxWidth="600"
        MaxHeight="600"
        SizeToContent="WidthAndHeight"
        WindowStartupLocation="CenterOwner"
        Background="#F5F7FA"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        WindowStyle="None"
        AllowsTransparency="True">
    <Border Background="#F5F7FA" CornerRadius="14" BorderBrush="#D7E2EC" BorderThickness="1" Padding="24">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                <Border Background="#E8F5E9" CornerRadius="20" Width="40" Height="40" Margin="0,0,14,0">
                    <TextBlock Text="&#xE8F5;" FontFamily="Segoe MDL2 Assets" FontSize="20"
                               Foreground="#2E7D32" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock x:Name="TitleText" Text="Update Available"
                               FontSize="18" FontWeight="Bold" Foreground="#17324D"/>
                    <TextBlock x:Name="VersionInfoText" Text=""
                               FontSize="13" Foreground="#7A8B9F" Margin="0,2,0,0"/>
                </StackPanel>
            </StackPanel>

            <StackPanel Grid.Row="1" Margin="0,0,0,10">
                <TextBlock x:Name="MessageText"
                           TextWrapping="Wrap" FontSize="14" Foreground="#4A5B6C"
                           Margin="0,0,0,6"/>
                <TextBlock x:Name="InstalledVersionText"
                           TextWrapping="Wrap" FontSize="12" Foreground="#7A8B9F"/>
            </StackPanel>

            <!-- Changelog link button — opens the GitHub release page for the current latest version -->
            <Button x:Name="ViewChangelogButton" Grid.Row="2" Margin="0,0,0,10"
                    Click="ViewChangelogButton_Click"
                    Cursor="Hand"
                    Background="Transparent"
                    BorderThickness="0"
                    Padding="0"
                    HorizontalAlignment="Left">
                <Border Background="#F0F4F8" BorderBrush="#D7E2EC" BorderThickness="1" CornerRadius="8" Padding="10,8">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE8A7;"
                                   FontFamily="Segoe MDL2 Assets"
                                   FontSize="12"
                                   Foreground="#1A73E8"
                                   VerticalAlignment="Center"
                                   Margin="0,0,6,0"/>
                        <TextBlock x:Name="ViewChangelogButtonText"
                                   Text="View Changelog on GitHub"
                                   FontSize="13"
                                   FontWeight="SemiBold"
                                   Foreground="#1A73E8"/>
                    </StackPanel>
                </Border>
            </Button>

            <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right">
                <Button x:Name="UpdateButton"
                        Content="Update Now"
                        Padding="16,9"
                        Background="#2E7D32"
                        Foreground="White"
                        BorderThickness="0"
                        Cursor="Hand"
                        FontWeight="SemiBold"
                        Margin="0,0,10,0"
                        Click="UpdateButton_Click"/>
                <Button Content="Later"
                        Padding="16,9"
                        Background="#E0E6ED"
                        Foreground="#17324D"
                        BorderThickness="0"
                        Cursor="Hand"
                        Click="LaterButton_Click"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
