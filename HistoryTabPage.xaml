<UserControl x:Class="AdHealthMonitor.HistoryTabPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
                    <Grid Margin="2">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0"
                                Background="{StaticResource SoftFillBrush}"
                                BorderBrush="{StaticResource PanelBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="14"
                                Padding="14"
                                Margin="0,0,0,12">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="220"/>
                                    <ColumnDefinition Width="160"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel>
                                    <TextBlock Text="Search" FontWeight="SemiBold" Foreground="{StaticResource HeadingBrush}" Margin="0,0,0,6"/>
                                    <TextBox x:Name="txtHistorySearch" x:FieldModifier="public" Style="{StaticResource ModernTextBoxStyle}" TextChanged="txtHistorySearch_TextChanged"/>
                                </StackPanel>

                                <StackPanel Grid.Column="1" Margin="12,0,0,0">
                                    <TextBlock Text="Filter by date" FontWeight="SemiBold" Foreground="{StaticResource HeadingBrush}" Margin="0,0,0,6"/>
                                    <DatePicker x:Name="dpHistoryFilter" x:FieldModifier="public" Style="{StaticResource ModernDatePickerStyle}" SelectedDateChanged="dpHistoryFilter_SelectedDateChanged"/>
                                </StackPanel>

                                <Button Grid.Column="3"
                                        Content="Clear Filters"
                                        Style="{StaticResource RoundedButtonStyle}"
                                        Background="#607D8B"
                                        Width="146"
                                        Height="40"
                                        Margin="12,0,6,0"
                                        VerticalAlignment="Bottom"
                                        Click="ClearHistoryFilters_Click"/>

                                <Button Grid.Column="4"
                                        x:Name="ViewSelectedRunButton" x:FieldModifier="public"
                                        Content="View Selected"
                                        Style="{StaticResource RoundedButtonStyle}"
                                        Background="#1A73E8"
                                        Width="154"
                                        Height="40"
                                        Margin="6,0,6,0"
                                        VerticalAlignment="Bottom"
                                        IsEnabled="False"
                                        Click="ViewSelectedHistoryRun_Click"/>

                                <Button Grid.Column="5"
                                        Content="Delete Selected"
                                        Style="{StaticResource RoundedButtonStyle}"
                                        Background="#D32F2F"
                                        Width="170"
                                        Height="40"
                                        Margin="6,0,6,0"
                                        VerticalAlignment="Bottom"
                                        Click="DeleteSelectedHistory_Click"/>

                                <Button Grid.Column="6"
                                        x:Name="CompareRunsButton" x:FieldModifier="public"
                                        Content="Compare Runs"
                                        Style="{StaticResource RoundedButtonStyle}"
                                        Background="#1A73E8"
                                        Width="150"
                                        Height="40"
                                        VerticalAlignment="Bottom"
                                        IsEnabled="False"
                                        Click="CompareRuns_Click"/>
                            </Grid>
                        </Border>

                        <Border Grid.Row="1"
                                Background="White"
                                BorderBrush="{StaticResource PanelBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="12">
                            <DataGrid x:Name="dgTestHistory" x:FieldModifier="public"
                                      AutoGenerateColumns="False"
                                      BorderThickness="0"
                                      CanUserAddRows="False"
                                      CanUserDeleteRows="False"
                                      IsReadOnly="True"
                                      RowHeaderWidth="0"
                                      RowHeight="44"
                                      HeadersVisibility="Column"
                                      GridLinesVisibility="Horizontal"
                                      SelectionMode="Extended"
                                      SelectionUnit="FullRow"
                                      AlternationCount="2"
                                      VirtualizingPanel.VirtualizationMode="Recycling"
                                       VirtualizingPanel.ScrollUnit="Item"
                                       PreviewMouseLeftButtonDown="DataGrid_CellPreviewMouseLeftButtonDown"
                                       SelectionChanged="dgTestHistory_SelectionChanged">
                                 <DataGrid.Resources>
                                     <Style TargetType="DataGridCell">
                                         <Setter Property="VerticalContentAlignment" Value="Center"/>
                                         <Setter Property="Padding" Value="8,0"/>
                                     </Style>
                                 </DataGrid.Resources>
                                 <DataGrid.Columns>
                                      <DataGridTemplateColumn Width="36">
                                          <DataGridTemplateColumn.Header>
                                              <CheckBox Style="{StaticResource HeaderCheckBoxStyle}"
                                                        HorizontalAlignment="Center"
                                                        VerticalAlignment="Center"
                                                        Checked="SelectAllCheckBox_Checked"
                                                        Unchecked="SelectAllCheckBox_Unchecked"/>
                                          </DataGridTemplateColumn.Header>
                                          <DataGridTemplateColumn.CellTemplate>
                                              <DataTemplate>
                                                  <Grid VerticalAlignment="Center">
                                                       <CheckBox Style="{StaticResource RowCheckBoxStyle}"
                                                                 HorizontalAlignment="Center"
                                                                 VerticalAlignment="Center"
                                                                 IsChecked="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type DataGridRow}}, Path=IsSelected, Mode=OneWay}"
                                                                        PreviewMouseLeftButtonDown="RowCheckBox_PreviewMouseLeftButtonDown"
                                                                        Checked="RowCheckBox_Checked"
                                                                        Unchecked="RowCheckBox_Unchecked"/>
                                                   </Grid>
                                               </DataTemplate>
                                          </DataGridTemplateColumn.CellTemplate>
                                      </DataGridTemplateColumn>
                                     <DataGridTextColumn Header="Run Date" Binding="{Binding RunDate, StringFormat={}{0:dd MMM yyyy HH:mm}}" Width="170">
                                         <DataGridTextColumn.ElementStyle>
                                             <Style TargetType="TextBlock">
                                                 <Setter Property="VerticalAlignment" Value="Center"/>
                                             </Style>
                                         </DataGridTextColumn.ElementStyle>
                                     </DataGridTextColumn>
                                    <DataGridTextColumn Header="Run Type" Binding="{Binding TestType}" Width="130">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="VerticalAlignment" Value="Center"/>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>
                                    <DataGridTextColumn Header="Total" Binding="{Binding Total}" Width="70">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="HorizontalAlignment" Value="Center"/>
                                                <Setter Property="VerticalAlignment" Value="Center"/>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>
                                    <DataGridTextColumn Header="Passed" Binding="{Binding Passed}" Width="78">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="HorizontalAlignment" Value="Center"/>
                                                <Setter Property="VerticalAlignment" Value="Center"/>
                                                <Setter Property="Foreground" Value="#2E7D32"/>
                                                <Setter Property="FontWeight" Value="SemiBold"/>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>
                                    <DataGridTextColumn Header="Failed" Binding="{Binding Failed}" Width="78">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="HorizontalAlignment" Value="Center"/>
                                                <Setter Property="VerticalAlignment" Value="Center"/>
                                                <Setter Property="Foreground" Value="#C62828"/>
                                                <Setter Property="FontWeight" Value="SemiBold"/>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>
                                    <DataGridTextColumn Header="Summary" Binding="{Binding Details}" Width="*">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="TextWrapping" Value="Wrap"/>
                                                <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                                                <Setter Property="VerticalAlignment" Value="Center"/>
                                                <Setter Property="MaxHeight" Value="36"/>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Border>
                    </Grid>
</UserControl>
