<Window x:Class="AdHealthMonitor.LoadingWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Loading"
        Width="360"
        Height="180"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        Background="Transparent"
        AllowsTransparency="True"
        ShowInTaskbar="False"
        Topmost="True">
    <Border Background="#F7FAFD"
            CornerRadius="16"
            BorderBrush="#D7E2EC"
            BorderThickness="1"
            Padding="24">
        <Border.Effect>
            <DropShadowEffect BlurRadius="14" ShadowDepth="3" Opacity="0.3" Color="Black"/>
        </Border.Effect>
        <StackPanel HorizontalAlignment="Center">
            <Grid Width="34" Height="34" HorizontalAlignment="Center" Margin="0,0,0,14">
                <Ellipse Width="34" Height="34"
                         Stroke="#E0E6ED" StrokeThickness="3"/>
                <Ellipse Width="34" Height="34"
                         Stroke="#1A73E8" StrokeThickness="3"
                         StrokeDashArray="18 60"
                         RenderTransformOrigin="0.5,0.5"
                         Loaded="Spinner_Loaded"
                         Unloaded="Spinner_Unloaded">
                    <Ellipse.RenderTransform>
                        <RotateTransform x:Name="SpinnerRotation"/>
                    </Ellipse.RenderTransform>
                </Ellipse>
            </Grid>

            <TextBlock x:Name="TitleTextBlock"
                       Text="Loading run results"
                       FontSize="16"
                       FontWeight="SemiBold"
                       Foreground="#13293D"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,6"/>
            <TextBlock x:Name="MessageTextBlock"
                       Text="Parsing the selected run and preparing the dashboard."
                       FontSize="13"
                       Foreground="#4F6479"
                       TextWrapping="Wrap"
                       TextAlignment="Center"
                       HorizontalAlignment="Center"/>
        </StackPanel>
    </Border>
</Window>
