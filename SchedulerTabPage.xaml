<UserControl x:Class="AdHealthMonitor.SchedulerTabPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
                    <Grid Margin="2">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Grid Grid.Row="1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1.5*"/>
                                <ColumnDefinition Width="1*"/>
                            </Grid.ColumnDefinitions>
                            <Border Background="#F8FAFC"
                                    BorderBrush="{StaticResource PanelBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="12"
                                    Padding="14"
                                    Margin="0,0,14,0">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="Scheduled Tasks"
                                                   FontSize="16"
                                                   FontWeight="SemiBold"
                                                   Foreground="{StaticResource HeadingBrush}"/>
                                        <TextBlock Text="Select a task to edit or remove."
                                                   FontSize="12"
                                                   Foreground="{StaticResource BodyBrush}"
                                                   Margin="0,2,0,10"/>
                                    </StackPanel>
                                    <DataGrid Grid.Row="1"
                                               x:Name="SchedulerTaskList" x:FieldModifier="public"
                                               AutoGenerateColumns="False"
                                               BorderThickness="0"
                                               AlternationCount="2"
                                               VirtualizingPanel.VirtualizationMode="Recycling"
                                               VirtualizingPanel.ScrollUnit="Item"
                                               RowHeaderWidth="0"
                                               RowHeight="40"
                                               HeadersVisibility="Column"
                                               GridLinesVisibility="Horizontal"
                                               SelectionMode="Extended"
                                               SelectionUnit="FullRow"
                                               PreviewMouseLeftButtonDown="DataGrid_CellPreviewMouseLeftButtonDown"
                                               SelectionChanged="SchedulerTaskList_SelectionChanged"
                                               CanUserAddRows="False"
                                               IsReadOnly="True">
                                         <DataGrid.Resources>
                                             <Style TargetType="TextBlock">
                                                 <Setter Property="VerticalAlignment" Value="Center"/>
                                                 <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                                             </Style>
                                             <Style TargetType="CheckBox">
                                                 <Setter Property="VerticalAlignment" Value="Center"/>
                                             </Style>
                                         </DataGrid.Resources>
                                         <DataGrid.CellStyle>
                                             <Style TargetType="DataGridCell">
                                                 <Setter Property="VerticalContentAlignment" Value="Center"/>
                                                 <Setter Property="Padding" Value="10,0"/>
                                                 <Setter Property="BorderThickness" Value="0"/>
                                                 <Setter Property="Background" Value="Transparent"/>
                                                 <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                                             </Style>
                                         </DataGrid.CellStyle>
                                         <DataGrid.Columns>
                                             <DataGridTemplateColumn Width="36">
                                                 <DataGridTemplateColumn.Header>
                                                     <CheckBox Style="{StaticResource HeaderCheckBoxStyle}"
                                                               HorizontalAlignment="Center"
                                                               VerticalAlignment="Center"
                                                               Checked="SelectAllCheckBox_Checked"
                                                               Unchecked="SelectAllCheckBox_Unchecked"/>
                                                 </DataGridTemplateColumn.Header>
                                                 <DataGridTemplateColumn.CellTemplate>
                                                     <DataTemplate>
                                                         <Grid VerticalAlignment="Center">
                                                             <CheckBox Style="{StaticResource RowCheckBoxStyle}"
                                                                       HorizontalAlignment="Center"
                                                                       VerticalAlignment="Center"
                                                                       Focusable="False"
                                                                       IsChecked="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type DataGridRow}}, Path=IsSelected, Mode=OneWay}"
                                                                       PreviewMouseLeftButtonDown="RowCheckBox_PreviewMouseLeftButtonDown"
                                                                       Checked="RowCheckBox_Checked"
                                                                       Unchecked="RowCheckBox_Unchecked"/>
                                                         </Grid>
                                                      </DataTemplate>
                                                  </DataGridTemplateColumn.CellTemplate>
                                              </DataGridTemplateColumn>
                                             <DataGridTemplateColumn Header="Task Name" Width="*">
                                                 <DataGridTemplateColumn.CellTemplate>
                                                     <DataTemplate>
                                                         <TextBlock Text="{Binding TaskName}"
                                                                    VerticalAlignment="Center"
                                                                    Margin="0,1,0,0"
                                                                    TextTrimming="CharacterEllipsis"/>
                                                     </DataTemplate>
                                                 </DataGridTemplateColumn.CellTemplate>
                                             </DataGridTemplateColumn>
                                            <DataGridTemplateColumn Header="DC" Width="1.2*">
                                                <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <TextBlock Text="{Binding DomainController}"
                                                                   VerticalAlignment="Center"
                                                                   Margin="0,1,0,0"
                                                                   TextTrimming="CharacterEllipsis"/>
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>
                                            </DataGridTemplateColumn>
                                            <DataGridTemplateColumn Header="Frequency" Width="90">
                                                <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <TextBlock Text="{Binding Frequency}"
                                                                   VerticalAlignment="Center"
                                                                   Margin="0,1,0,0"
                                                                   TextTrimming="CharacterEllipsis"/>
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>
                                            </DataGridTemplateColumn>
                                            <DataGridTemplateColumn Header="Date" Width="80">
                                                <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <TextBlock Text="{Binding StartDate, StringFormat={}{0:dd MMM}}"
                                                                   VerticalAlignment="Center"
                                                                   Margin="0,1,0,0"
                                                                   TextTrimming="CharacterEllipsis"/>
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>
                                            </DataGridTemplateColumn>
                                            <DataGridTemplateColumn Header="Time" Width="65">
                                                <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <TextBlock Text="{Binding StartTime}"
                                                                   VerticalAlignment="Center"
                                                                   Margin="0,1,0,0"
                                                                   TextTrimming="CharacterEllipsis"/>
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>
                                            </DataGridTemplateColumn>
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </Grid>
                            </Border>

                            <StackPanel Grid.Column="1">
                                <Border Background="White"
                                        BorderBrush="{StaticResource PanelBorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="12"
                                        Padding="18">
                                    <StackPanel>
                                        <TextBlock Text="Create or Edit Task"
                                                   FontSize="16"
                                                   FontWeight="SemiBold"
                                                   Foreground="{StaticResource HeadingBrush}"
                                                   Margin="0,0,0,4"/>
                                        <TextBlock Text="Set up recurring AD health checks."
                                                   Foreground="{StaticResource BodyBrush}"
                                                   FontSize="13"
                                                   Margin="0,0,0,12"/>

                                        <TextBlock Text="Task Name" FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource HeadingBrush}"/>
                                        <TextBox x:Name="SchedulerTaskName" x:FieldModifier="public"
                                                 FontSize="14"
                                                 Padding="8"
                                                 Height="38"
                                                 BorderBrush="#C7D5E2"
                                                 BorderThickness="1"
                                                 Background="White"
                                                 Margin="0,4,0,10"/>

                                        <TextBlock Text="Domain Controllers" FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource HeadingBrush}"/>
                                        <TextBox x:Name="SchedulerDomainControllers" x:FieldModifier="public"
                                                 FontSize="14"
                                                 Padding="8"
                                                 Height="60"
                                                 BorderBrush="#C7D5E2"
                                                 BorderThickness="1"
                                                 Background="White"
                                                 Margin="0,4,0,10"
                                                 AcceptsReturn="True"
                                                 TextWrapping="Wrap"
                                                 VerticalScrollBarVisibility="Auto"/>

                                        <TextBlock Text="Frequency" FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource HeadingBrush}"/>
                                        <ComboBox x:Name="SchedulerFrequency" x:FieldModifier="public"
                                                  FontSize="14"
                                                  Padding="5"
                                                  Height="38"
                                                  BorderBrush="#C7D5E2"
                                                  BorderThickness="1"
                                                  Background="White"
                                                  Margin="0,4,0,10"
                                                  SelectedIndex="0">
                                            <ComboBoxItem Content="Daily"/>
                                            <ComboBoxItem Content="Weekly"/>
                                            <ComboBoxItem Content="Monthly"/>
                                            <ComboBoxItem Content="Hourly"/>
                                        </ComboBox>

                                        <Grid Margin="0,0,0,10">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" Margin="0,0,6,0">
                                                <TextBlock Text="Start Date" FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource HeadingBrush}"/>
                                                <DatePicker x:Name="SchedulerStartDate" x:FieldModifier="public"
                                                            FontSize="14"
                                                            Padding="5"
                                                            Height="38"
                                                            BorderBrush="#C7D5E2"
                                                            BorderThickness="1"
                                                            Background="White"
                                                            Margin="0,4,0,0"/>
                                            </StackPanel>
                                            <StackPanel Grid.Column="1" Margin="6,0,0,0">
                                                <TextBlock Text="Start Time" FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource HeadingBrush}"/>
                                                <TextBlock Text="Use 24-hour format, e.g. 14:30 for 2:30 PM" FontSize="11" Foreground="{StaticResource BodyBrush}" Margin="0,2,0,0"/>
                                                <TextBox x:Name="SchedulerStartTime" x:FieldModifier="public"
                                                         FontSize="14"
                                                         Padding="8"
                                                         Height="38"
                                                         BorderBrush="#C7D5E2"
                                                         BorderThickness="1"
                                                         Background="White"
                                                         Margin="0,4,0,0"/>
                                            </StackPanel>
                                        </Grid>

                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,6,0,0">
                                            <Button Content="Save"
                                                    Style="{StaticResource RoundedButtonStyle}"
                                                    Background="{StaticResource SidebarActiveBrush}"
                                                    Width="80"
                                                    Margin="0,0,10,0"
                                                    Click="SchedulerSaveButton_Click"/>
                                            <Button Content="Remove"
                                                    Style="{StaticResource RoundedButtonStyle}"
                                                    Background="#D32F2F"
                                                    Width="90"
                                                    Click="SchedulerRemoveButton_Click"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Grid>
                    </Grid>
</UserControl>
